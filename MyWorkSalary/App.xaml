<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MyWorkSalary"
             xmlns:converters="clr-namespace:MyWorkSalary.Helpers.Converters"
             x:Class="MyWorkSalary.App">
    
    <Application.Resources>
        <ResourceDictionary>
            
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Registrera Converters -->
            <converters:BoolToTextColorConverter x:Key="BoolToTextColorConverter" />
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />

            <!-- Nya job converters från JobConverters.cs -->
            <converters:BoolToJobBackgroundConverter x:Key="BoolToJobBackgroundConverter" />
            <converters:BoolToJobTextColorConverter x:Key="BoolToJobTextColorConverter" />
            <converters:BoolToJobSubTextColorConverter x:Key="BoolToJobSubTextColorConverter" />
            <converters:BoolToRadioSymbolConverter x:Key="BoolToRadioSymbolConverter" />

            <!-- Shift Converters från ShiftConverters.cs -->
            <converters:ShiftTypeToIconConverter x:Key="ShiftTypeToIconConverter" />
            <converters:ShiftToDateStringConverter x:Key="ShiftToDateStringConverter" />
            <converters:ShiftToTimeStringConverter x:Key="ShiftToTimeStringConverter" />
            <converters:IsGreaterThanZeroConverter x:Key="IsGreaterThanZeroConverter" />
            

        </ResourceDictionary>
    </Application.Resources>
</Application>
