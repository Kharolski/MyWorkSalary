<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Name="ShiftPageRef"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization"
             xmlns:components="clr-namespace:MyWorkSalary.Views.Components"
             x:Class="MyWorkSalary.Views.ShiftPage"
             Title="{resx:Translate ShiftPageTitle}">
    
    <Grid>
        <!-- Main Content -->
        <ScrollView IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}">
            <VerticalStackLayout Spacing="20" Padding="20">

                <!-- Header med aktivt jobb -->
                <Border Style="{StaticResource CardBorder}" IsVisible="{Binding HasActiveJob}">
                    <VerticalStackLayout Spacing="5">
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Grid.Column="0" 
                                   Text="{resx:Translate ActiveJobLabel}"
                                   Style="{StaticResource ActiveJobTitleLabel}"
                                   TextColor="{AppThemeBinding Light={StaticResource ActiveJobLight},
                                                Dark={StaticResource ActiveJobDark}}"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding ActiveJobTitle}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource ActiveJobLight},
                                                               Dark={StaticResource ActiveJobDark}}" />
                        </Grid>

                        <!-- Företag och lön under i separata rader -->
                        <Label Text="{Binding Workplace}" FontSize="14" 
                               Style="{StaticResource SecondaryLabel}" Padding="23,0,0,0"
                               TextColor="{AppThemeBinding Light={StaticResource ActiveJobLight},
                                Dark={StaticResource ActiveJobDark}}"/>

                        <Label Text="{Binding SalaryDisplayText}" Padding="23,0,0,0" FontSize="12" Style="{StaticResource SecondaryLabel}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Lägg till pass knapp -->
                <Button Text="{resx:Translate AddShiftButton}"
                        Command="{Binding AddShiftCommand}"
                        IsVisible="{Binding HasActiveJob}"
                        Style="{StaticResource ButtonAdd}"
                        Padding="0,15"
                        FontSize="16" />

                <!-- Lista med pass -->
                <Label Text="{resx:Translate MyShiftsHeader}"
                       Style="{StaticResource SectionHeaderLabel}"
                       IsVisible="{Binding HasActiveJob}"
                       Margin="0,10,0,0" />

            <!-- Meddelande när inga pass finns -->
            <Border Style="{StaticResource EmptyStateBorder}"
                   IsVisible="{Binding NoShiftsVisible}">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="{resx:Translate NoShiftsIcon}"
                           FontSize="40"
                           HorizontalOptions="Center" />
                    <Label Text="{resx:Translate NoShiftsTitle}"
                           FontSize="16"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                                      Dark={StaticResource TextPrimaryDark}}" />
                    <Label Text="{resx:Translate NoShiftsMessage}"
                           Style="{StaticResource SecondaryLabel}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- No Job kort -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding HasNoActiveJob}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="🗓️" FontSize="40"  HorizontalOptions="Center" />
                    <Label Text="{resx:Translate NoActiveJob}"
                        FontSize="20" FontAttributes="Bold"
                        HorizontalOptions="Center"
                        Style="{StaticResource ActiveJob}" />
                    <Label Text="{resx:Translate GetStartedShiftPrompt}"
                        Style="{StaticResource SecondaryLabel}"
                        HorizontalOptions="Center" />
                    <Button Text="{resx:Translate CreateFirstJob}"
                            Command="{Binding CreateJobCommand}"
                            Style="{StaticResource ButtonAdd}"
                            Margin="0,10,0,0"
                            HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

                <!-- GRUPPERAD LISTA MED PASS -->
            <CollectionView ItemsSource="{Binding GroupedWorkShifts}"
                            IsVisible="{Binding HasShifts}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Spacing="10" Margin="0,0,0,20">

                            <!-- MÅNADS-HEADER MED EXPAND/COLLAPSE -->
                            <Border BackgroundColor="{StaticResource ActiveJobLight}"
                                   Padding="15,10"
                                   StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding MonthYear, StringFormat='{0}'}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource White}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding HoursSummary}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource White}"
                                           Margin="0,4,10,0" />

                                    <!-- EXPAND/COLLAPSE PIL -->
                                    <Label Grid.Column="2" Text="{Binding ExpandIcon}" FontSize="20" TextColor="{StaticResource White}" VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding ToggleExpandCommand}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>

                            <!-- PASS I DENNA MÅNAD MED SWIPE -->
                            <CollectionView ItemsSource="{Binding}" IsVisible="{Binding IsExpanded}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <SwipeView>
                                            <!-- SWIPE ACTIONS (Vänster swipe) -->
                                            <SwipeView.RightItems>
                                                <SwipeItems>
                                                    <SwipeItem Text="{resx:Translate Delete}"
                                                               BackgroundColor="{StaticResource ButtonDanger}"
                                                               Command="{Binding Source={x:Reference ShiftPageRef}, Path=BindingContext.DeleteShiftCommand}"
                                                               CommandParameter="{Binding .}" />
                                                </SwipeItems>
                                            </SwipeView.RightItems>

                                            <!-- PASS-KORT -->
                                            <Grid Padding="0,2">
                                                <Border Style="{StaticResource CardBorder}" Margin="10,0">
                                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto, Auto">
                                                        <!-- PASS-TYP IKON -->
                                                        <Label Grid.Row="0" Grid.Column="0"
                                                               Text="{Binding ., Converter={StaticResource ShiftTypeToIconConverter}}"
                                                               FontSize="16"
                                                               VerticalOptions="Center"
                                                               Margin="0,0,10,0"
                                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                           Dark={StaticResource TextPrimaryDark}}" />

                                                        <!-- DATUM OCH VECKODAG -->
                                                        <Label Grid.Row="0" Grid.Column="1"
                                                               Text="{Binding ., Converter={StaticResource ShiftToDateStringConverter}}"
                                                               FontSize="16" Margin="10,0,0,0"
                                                               FontAttributes="Bold"
                                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                           Dark={StaticResource TextPrimaryDark}}" />

                                                        <!-- TIMMAR -->
                                                        <Label Grid.Row="0" Grid.Column="2"
                                                               Text="{Binding ., Converter={StaticResource ShiftToHoursDisplayConverter}}"
                                                               FontSize="16"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource ButtonPrimary}" />

                                                        <!-- ARBETSTIDER / PERIOD INFO -->
                                                        <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                                               Text="{Binding ., Converter={StaticResource ShiftToTimeStringConverter}}"
                                                               FontSize="14" 
                                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                                                           Dark={StaticResource TextSecondaryDark}}"
                                                               Margin="10,2,0,0" />

                                                        <!-- EXTRA PASS STATUS -->
                                                        <Label Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                                               Text="{Binding ., Converter={StaticResource ShiftToExtraShiftStatusTextConverter}}"
                                                               IsVisible="{Binding ., Converter={StaticResource ShiftToShowExtraShiftStatusConverter}}"
                                                               FontSize="12"
                                                               FontAttributes="Italic"
                                                               TextColor="{Binding ., Converter={StaticResource ShiftToExtraShiftStatusColorConverter}}"
                                                               Margin="10,0,0,0" />
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </SwipeView>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

        <!-- Loading Overlay (under ad banner) -->
        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A1A}">
            <Grid HorizontalOptions="Center" VerticalOptions="Center">

                <!-- Skeleton cards -->
                <VerticalStackLayout Spacing="20">
                    <components:SkeletonCard />
                    <components:SkeletonCard />
                    <components:SkeletonCard />
                </VerticalStackLayout>

                <!-- Loading indicator centered -->
                <components:LoadingIndicator HorizontalOptions="Center" VerticalOptions="Center" />
            </Grid>
        </Grid>

        <!-- Ad Banner Layer (överst, alltid synlig) -->
        <Grid x:Name="AdBannerContainer" VerticalOptions="Start" HorizontalOptions="Fill" HeightRequest="50" />
    </Grid>
</ContentPage>
