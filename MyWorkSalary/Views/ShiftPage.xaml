<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Name="ShiftPageRef"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyWorkSalary.Views.ShiftPage"
             Title="Arbetspass">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Header med aktivt jobb -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="📋 Aktivt jobb"
                           Style="{StaticResource ActiveJobTitleLabel}" />
                    <Label Text="{Binding ActiveJobTitle}"
                           FontSize="18"
                           TextColor="{AppThemeBinding Light={StaticResource ActiveJobLight}, 
                                                      Dark={StaticResource ActiveJobDark}}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Lägg till pass knapp -->
            <Button Text="➕ Lägg till nytt pass"
                    Command="{Binding AddShiftCommand}"
                    Style="{StaticResource ButtonAdd}"
                    Padding="0,15"
                    FontSize="16" />

            <!-- Lista med pass -->
            <Label Text="📅 Mina arbetspass"
                   Style="{StaticResource SectionHeaderLabel}"
                   Margin="0,10,0,0" />

            <!-- Meddelande när inga pass finns -->
            <Frame Style="{StaticResource EmptyStateFrame}"
                   IsVisible="{Binding NoShiftsVisible}">
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="📝"
                           FontSize="40"
                           HorizontalOptions="Center" />
                    <Label Text="Inga arbetspass registrerade än"
                           FontSize="16"
                           HorizontalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                                      Dark={StaticResource TextPrimaryDark}}" />
                    <Label Text="Tryck på knappen ovan för att lägga till ditt första pass"
                           Style="{StaticResource SecondaryLabel}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- GRUPPERAD LISTA MED PASS -->
            <CollectionView ItemsSource="{Binding GroupedWorkShifts}"
                            IsVisible="{Binding HasShifts}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Spacing="10" Margin="0,0,0,20">

                            <!-- MÅNADS-HEADER -->
                            <Frame BackgroundColor="{StaticResource ActiveJobLight}"
                                   Padding="15,10"
                                   CornerRadius="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding MonthYear, StringFormat='{0}'}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource White}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding TotalHours, StringFormat='({0:F1}t)'}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource White}" />
                                </Grid>
                            </Frame>

                            <!-- PASS I DENNA MÅNAD MED SWIPE -->
                            <CollectionView ItemsSource="{Binding .}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <SwipeView>
                                            <!-- SWIPE ACTIONS (Vänster swipe) -->
                                            <SwipeView.RightItems>
                                                <SwipeItems>
                                                    <SwipeItem Text="🗑️ Radera"
                                                               BackgroundColor="{StaticResource ButtonDanger}"
                                                               Command="{Binding Source={x:Reference ShiftPageRef}, Path=BindingContext.DeleteShiftCommand}"
                                                               CommandParameter="{Binding .}" />
                                                </SwipeItems>
                                            </SwipeView.RightItems>

                                            <!-- PASS-KORT -->
                                            <Grid Padding="0,2">
                                                <Frame Style="{StaticResource CardFrame}" Margin="10,0">
                                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                                                        <!-- PASS-TYP IKON -->
                                                        <Label Grid.Row="0" Grid.Column="0"
                                                               Text="{Binding ., Converter={StaticResource ShiftTypeToIconConverter}}"
                                                               FontSize="16"
                                                               VerticalOptions="Center"
                                                               Margin="0,0,10,0"
                                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                           Dark={StaticResource TextPrimaryDark}}" />

                                                        <!-- DATUM OCH VECKODAG -->
                                                        <Label Grid.Row="0" Grid.Column="1"
                                                               Text="{Binding ., Converter={StaticResource ShiftToDateStringConverter}}"
                                                               FontSize="16" Margin="10,0,0,0"
                                                               FontAttributes="Bold"
                                                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                                                           Dark={StaticResource TextPrimaryDark}}" />

                                                        <!-- TIMMAR -->
                                                        <Label Grid.Row="0" Grid.Column="2"
                                                               Text="{Binding ., Converter={StaticResource ShiftToHoursDisplayConverter}}"
                                                               FontSize="16"
                                                               FontAttributes="Bold"
                                                               TextColor="{StaticResource ButtonPrimary}" />

                                                        <!-- ARBETSTIDER / PERIOD INFO -->
                                                        <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                                               Text="{Binding ., Converter={StaticResource ShiftToTimeStringConverter}}"
                                                               FontSize="14" 
                                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                                                           Dark={StaticResource TextSecondaryDark}}"
                                                               Margin="10,2,0,0" />
                                                    </Grid>
                                                </Frame>
                                            </Grid>
                                        </SwipeView>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
