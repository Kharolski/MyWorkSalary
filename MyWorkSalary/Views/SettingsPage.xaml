<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.SettingsPage"
             x:Name="SettingsPageRef"
             xmlns:local="clr-namespace:MyWorkSalary.Views"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{resx:Translate AppSettings}">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Kombinerad Jobb Sektion -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="15">
                    <!-- EN rubrik för allt -->
                    <Label Text="{resx:Translate MyJobs}" Style="{StaticResource SectionTitleLabel}"/>
                    
                    <!-- Visa när inga jobb finns -->
                    <StackLayout IsVisible="{Binding HasNoJobs}" Spacing="10" Margin="10"
                             VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand">

                        <Label Text="📋" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="{resx:Translate NoJobsRegistered}" FontSize="18" 
                               FontAttributes="Bold" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                               Dark={StaticResource TextPrimaryDark}}" />

                        <Label Text="{resx:Translate AddFirstJobText}" FontSize="14"
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                               Dark={StaticResource TextPrimaryDark}}" />

                    </StackLayout>

                    <CollectionView ItemsSource="{Binding AllJobs}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <!-- SwipeView -->
                                <SwipeView>
                                    <!-- Swipe från höger för att radera -->
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="{resx:Translate Delete}"
                                                      BackgroundColor="{StaticResource ButtonCancel}"
                                                      Command="{Binding Source={x:Reference SettingsPageRef}, Path=BindingContext.DeleteJobCommand}"
                                                      CommandParameter="{Binding .}" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <!-- Enhetligt job-kort design -->
                                    <Border Padding="0"
                                            Margin="0,2"
                                            BackgroundColor="{Binding IsActive, Converter={StaticResource BoolToJobBackgroundConverter}}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8" />
                                        </Border.StrokeShape>
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="12,10">
                                            <!-- Klickbar BARA om det finns flera jobb -->
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ChangeActiveJobCommand}"
                                                    CommandParameter="{Binding .}"
                                                    NumberOfTapsRequired="1" />
                                            </Grid.GestureRecognizers>

                                            <!-- Radio-symbol (visa alltid) -->
                                            <Label Grid.Column="0"
                                                   Text="{Binding IsActive, Converter={StaticResource BoolToRadioSymbolConverter}}"
                                                   FontSize="18"
                                                   TextColor="{StaticResource ActiveJobBlue}"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center" />

                                            <!-- Jobb-information -->
                                            <StackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                                <Label Text="{Binding JobTitle}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="{Binding IsActive, Converter={StaticResource BoolToJobTextColorConverter}}" />
                                                <Label Text="{Binding Workplace}"
                                                       FontSize="14"
                                                       TextColor="{Binding IsActive, Converter={StaticResource BoolToJobSubTextColorConverter}}" />
                                                <Label Text="{Binding SalaryDisplayText}"
                                                       FontSize="12"
                                                       Style="{StaticResource SecondaryLabel}"
                                                       Margin="0,2,0,0" />
                                            </StackLayout>

                                            <!-- Aktiv-indikator -->
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{StaticResource ActiveJobBlue}"
                                                    Padding="6,2"
                                                    StrokeShape="RoundRectangle 4"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Start"
                                                    IsVisible="{Binding IsActive}">
                                                <Label Text="{resx:Translate Active}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource White}"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Knappar bredvid varandra -->
                    <StackLayout Orientation="Horizontal"
                                 Spacing="8"
                                 HorizontalOptions="FillAndExpand"
                                 Margin="0,10,0,0">
                        <!-- 1. Lägg till (Grön) -->
                        <Button Text="{resx:Translate AddJob}"
                                Command="{Binding AddJobCommand}"
                                BackgroundColor="{StaticResource ButtonPrimary}"
                                TextColor="{StaticResource White}"
                                CornerRadius="8"
                                Padding="0,12"
                                HorizontalOptions="FillAndExpand" />
                        <!-- 2. Ändra (Orange) -->
                        <Button Text="{resx:Translate EditJob}"
                                Command="{Binding EditActiveJobCommand}"
                                Style="{StaticResource EditButton}"
                                HorizontalOptions="FillAndExpand"
                                IsVisible="{Binding HasActiveJob}" />
                    </StackLayout>

                    <!-- Hjälptext (visa alltid när det finns jobb) -->
                    <Label Text="{resx:Translate SwipeDeleteJobHint}"
                           FontSize="12"
                           Style="{StaticResource TipsLabel}"
                           HorizontalOptions="Center"
                           IsVisible="{Binding HasActiveJob}"
                           Margin="0,5,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- Jobbinställningar-knapp -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding HasActiveJob}">
                <Grid ColumnDefinitions="*,Auto" Padding="12">
                    <Label Text="{resx:Translate JobSettings_Title}" Style="{StaticResource SectionTitleLabel}" />

                    <!-- Pil-ikon -->
                    <Label Grid.Column="1"
                           Text="▶" FontSize="22" Margin="0,-3,0,0" FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                      Dark={StaticResource TextPrimaryDark}}" />
                    <!-- Klick -->
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenJobSettingsCommand}" />
                    </Grid.GestureRecognizers>

                </Grid>
            </Border>

            <!-- App Inställningar -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="15">

                    <Label Text="{resx:Translate AppSettings}"
                           Style="{StaticResource SectionTitleLabel}" />

                    <!-- Tema-växlare -->
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12"
                          Padding="8,4">

                        <!-- Tema-ikon -->
                        <Label Grid.Column="0"
                               Text="{Binding IsDarkTheme, Converter={StaticResource ThemeToIconConverter}}"
                               FontSize="20"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                                          Dark={StaticResource TextPrimaryDark}}" />

                        <!-- Tema-text -->
                        <StackLayout Grid.Column="1"
                                     Spacing="2"
                                     VerticalOptions="Center">
                            <Label Text="{resx:Translate DarkTheme}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                                              Dark={StaticResource TextPrimaryDark}}" />
                            <Label Text="{Binding ThemeDescription}"
                                   FontSize="12"
                                   Style="{StaticResource SecondaryLabel}" />
                        </StackLayout>

                        <!-- Custom Switch med synlig track -->
                        <Border Grid.Column="2"
                            BackgroundColor="{AppThemeBinding Light={StaticResource SwitchTrackOff}, 
                                                            Dark={StaticResource SwitchTrackOffDark}}"
                            Padding="2"
                            HeightRequest="30"
                            WidthRequest="50"
                            VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15" />
                            </Border.StrokeShape>
                            <Switch IsToggled="{Binding IsDarkTheme}"
                                    OnColor="{StaticResource ButtonPrimary}"
                                    ThumbColor="{AppThemeBinding Light={StaticResource SwitchThumbLight}, 
                                                                Dark={StaticResource White}}"
                                    BackgroundColor="Transparent"
                                    Scale="0.8" />
                        </Border>
                    </Grid>

                    <!-- Språk-växlare -->
                    <Grid ColumnDefinitions="Auto,*" Padding="8,4" ColumnSpacing="12">
                        <!-- Ikon -->
                        <Label Grid.Column="0"
                               Text="🌍"
                               FontSize="20"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                                              Dark={StaticResource TextPrimaryDark}}" />

                        <!-- Dropdown för språk -->
                        <Picker Grid.Column="1"
                                Title="{resx:Translate ChooseLanguage}" 
                                ItemsSource="{Binding AvailableLanguages}"
                                ItemDisplayBinding="{Binding DisplayName}"
                                SelectedItem="{Binding SelectedLanguage}"
                                FontSize="14"
                                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                                               Dark={StaticResource TextPrimaryDark}}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Om appen-knapp -->
            <Border Style="{StaticResource CardBorder}">
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="12" ColumnSpacing="12">

                    <!-- Ikon -->
                    <Label Grid.Column="0"
                           Text="ℹ️"
                           FontSize="22"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                      Dark={StaticResource TextPrimaryDark}}" />
                    <!-- Titel -->
                    <Label Grid.Column="1" Text="{resx:Translate AboutApp}" Style="{StaticResource SectionTitleLabel}" />

                    <!-- Pil -->
                    <Label Grid.Column="2"
                           Text="▶"
                           FontSize="22"
                           Margin="0,-3,0,0"
                           FontAttributes="Bold"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                      Dark={StaticResource TextPrimaryDark}}" />
                    <!-- Klick -->
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenAboutAppCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
