<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Inställningar">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Kombinerad Jobb Sektion -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="15">
                    <!-- EN rubrik för allt -->
                    <Label Text="💼 Mina Jobb"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource SalaryPrimary}" />

                    <!-- Visa aktivt jobb BARA när det finns 1 jobb -->
                    <StackLayout IsVisible="{Binding HasMultipleJobs, Converter={StaticResource InvertedBoolConverter}}"
                                 Spacing="5">
                        
                        <Frame BackgroundColor="{StaticResource ActiveJobBlue}"
                               Padding="12,8"
                               CornerRadius="8"
                               HasShadow="False">
                            <Label Text="{Binding ActiveJobText}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center" />
                        </Frame>
                    </StackLayout>

                    <!-- Visa radio buttons när det finns flera jobb -->
                    <StackLayout IsVisible="{Binding HasMultipleJobs}" Spacing="10">
                        
                        <CollectionView ItemsSource="{Binding AllJobs}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Frame Padding="0"
                                           Margin="0,2"
                                           CornerRadius="8"
                                           HasShadow="False"
                                           BackgroundColor="{Binding IsActive, Converter={StaticResource BoolToJobBackgroundConverter}}">
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="12"
                                              Padding="12,10">
                                            <!-- Hela raden klickbar -->
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ChangeActiveJobCommand}"
                                                    CommandParameter="{Binding .}"
                                                    NumberOfTapsRequired="1" />
                                            </Grid.GestureRecognizers>

                                            <!-- Ersätt RadioButton med emoji -->
                                            <Label Grid.Column="0"
                                                   Text="{Binding IsActive, Converter={StaticResource BoolToRadioSymbolConverter}}"
                                                   FontSize="18"
                                                   TextColor="{StaticResource ActiveJobBlue}"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center" />

                                            <!-- Jobb info -->
                                            <StackLayout Grid.Column="1"
                                                         Spacing="3"
                                                         VerticalOptions="Center">
                                                <Label Text="{Binding JobTitle}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="{Binding IsActive, Converter={StaticResource BoolToJobTextColorConverter}}" />
                                                <Label Text="{Binding Workplace}"
                                                       FontSize="14"
                                                       TextColor="{Binding IsActive, Converter={StaticResource BoolToJobSubTextColorConverter}}" />
                                            </StackLayout>

                                            <!-- Aktiv indikator med Border -->
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{StaticResource ActiveJobBlue}"
                                                    Padding="6,2"
                                                    StrokeShape="RoundRectangle 4"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Start"
                                                    IsVisible="{Binding IsActive}">
                                                <Label Text="✓ AKTIV"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       TextColor="White"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>

                    <!-- Knappar bredvid varandra -->
                    <StackLayout Orientation="Horizontal" 
                                 Spacing="8" 
                                 HorizontalOptions="FillAndExpand"
                                 Margin="0,10,0,0">

                        <!-- 1. Lägg till (Grön) -->
                        <Button Text="✚ Lägg till"
                                Command="{Binding AddJobCommand}"
                                BackgroundColor="{StaticResource SalaryPrimary}"
                                TextColor="White"
                                CornerRadius="8"
                                Padding="0,12"
                                HorizontalOptions="FillAndExpand" />

                        <!-- 2. Ändra (Orange) -->
                        <Button Text="✏️ Ändra"
                                Command="{Binding EditActiveJobCommand}"
                                BackgroundColor="Orange"
                                TextColor="White"
                                CornerRadius="8"
                                Padding="0,12"
                                HorizontalOptions="FillAndExpand"
                                IsVisible="{Binding HasActiveJob}" />

                        <!-- 3. Radera (Röd) -->
                        <Button Text="🗑️"
                                Command="{Binding DeleteActiveJobCommand}"
                                BackgroundColor="Red"
                                TextColor="White"
                                CornerRadius="8"
                                Padding="12"
                                WidthRequest="50"
                                IsVisible="{Binding HasActiveJob}" />

                    </StackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- App Inställningar -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🔧 App-inställningar"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource SalaryPrimary}" />
                    <Label Text="Kommer snart..."
                           Style="{StaticResource SecondaryLabel}" />

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
