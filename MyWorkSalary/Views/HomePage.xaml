<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.HomePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization"
             Title="{resx:Translate HomeTitle}">
      
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!--Välkomst-kort-->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding WelcomeText}"
                           Style="{StaticResource ActiveJob}" 
                           HorizontalOptions="Center" FontAttributes="Bold"
                           FontSize="20" />

                     <!--Visa när inget jobb finns--> 
                    <StackLayout IsVisible="{Binding ShowSetupButton}">
                        <Label Text="{resx:Translate GetStartedPrompt}"
                               Style="{StaticResource SecondaryLabel}"
                               HorizontalOptions="Center" />
                        <Button Text="{resx:Translate CreateFirstJob}"
                                Command="{Binding SetupJobCommand}" Margin="0,10,0,0"
                                HorizontalOptions="Center" />
                    </StackLayout>

                     <!--Visa när jobb finns--> 
                    <StackLayout IsVisible="{Binding HasActiveJob}" Spacing="5">
                        <Label Text="{Binding WorkplaceText}"
                               Style="{StaticResource ActiveJob}"
                               FontSize="16" Margin="0,-10,0,0"
                               HorizontalOptions="Center" />
                        
                        <Label Text="{Binding SalaryTypeInfo}" 
                               Style="{StaticResource SecondaryLabel}"
                               FontSize="12"
                               HorizontalOptions="Center" />
                    </StackLayout>
                </VerticalStackLayout>
            </Border>

             <!--Dashboard innehåll (bara när jobb finns)--> 
            <StackLayout IsVisible="{Binding ShowDashboard}" Spacing="20">

                <!--Månadens statistik-->
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="{Binding CurrentMonthYear}" Style="{StaticResource SectionTitleLabel}" />
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="25" RowSpacing="20">

                            <!-- Timmar -->
                            <VerticalStackLayout Grid.Column="0" Grid.Row="0" Spacing="4" HorizontalOptions="Center">
                                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="⏰" FontSize="20" />
                                    <Label Text="{Binding MonthlyHoursText}" FontAttributes="Bold" FontSize="18" />
                                </HorizontalStackLayout>
                                <Label Text="{resx:Translate HoursText}"
                                       Style="{StaticResource SecondaryLabel}"
                                       FontSize="12"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <!-- Arbetsdagar -->
                            <VerticalStackLayout Grid.Column="1" Grid.Row="0" Spacing="4" HorizontalOptions="Center">
                                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="📅" FontSize="20" />
                                    <Label Text="{Binding WorkDaysThisMonth}" FontAttributes="Bold" FontSize="18" />
                                </HorizontalStackLayout>
                                <Label Text="{resx:Translate WorkDays}"
                                       Style="{StaticResource SecondaryLabel}"
                                       FontSize="12"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <!-- OB före mån -->
                            <VerticalStackLayout Grid.Column="0" Grid.Row="1" Spacing="4" HorizontalOptions="Center">
                                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="🌙" FontSize="20" />
                                    <Label Text="{Binding ObHoursPaidThisMonthText}" FontAttributes="Bold" FontSize="18" />
                                </HorizontalStackLayout>
                                <Label Text="{resx:Translate ObBeforeMonth}"
                                       Style="{StaticResource SecondaryLabel}"
                                       FontSize="12"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>

                            <!-- OB denna mån -->
                            <VerticalStackLayout Grid.Column="1" Grid.Row="1" Spacing="4" HorizontalOptions="Center">
                                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="🌙" FontSize="20" />
                                    <Label Text="{Binding MonthlyObHoursText}" FontAttributes="Bold" FontSize="18" />
                                </HorizontalStackLayout>
                                <Label Text="{resx:Translate ObThisMonth}"
                                       Style="{StaticResource SecondaryLabel}"
                                       FontSize="12"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>

                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!--Flex-tid sektion (bara för månadslön)-->
                <Border Style="{StaticResource CardBorder}" IsVisible="{Binding ShowFlexSection}">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="{resx:Translate FlexTime}" Style="{StaticResource SectionTitleLabel}" />

                         <!--Aktuellt saldo--> 
                        <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="10">
                            <Label Text="{Binding FlexStatusIcon}" FontSize="24" VerticalOptions="Center" />
                            <Label Text="{Binding FlexBalanceText}" FontAttributes="Bold" FontSize="18" TextColor="{Binding FlexBalanceColor}" VerticalOptions="Center" />
                        </StackLayout>

                        <!--Förklaringstext-->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="20">

                            <Label Text="{resx:Translate FlexTimeTooltip}" 
                                   Style="{StaticResource SecondaryLabel}" FontSize="12" HorizontalOptions="Center" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!--Snabbknappar-->
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="{resx:Translate QuickActions}" Style="{StaticResource SectionTitleLabel}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                            <Button Grid.Column="0"
                                    Text="{resx:Translate AddShift}"
                                    Command="{Binding AddShiftCommand}"
                                    Style="{StaticResource ButtonAdd}" />

                            <Button Grid.Column="1"
                                    Text="{resx:Translate ViewReports}"
                                    Command="{Binding ViewReportsCommand}"
                                    Style="{StaticResource SecondaryButton}" />
                        </Grid>

                         <!--HJÄLPTEXT-->
                        <Label Text="{resx:Translate QuickActionsTooltip}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, 
                                                           Dark={StaticResource TextSecondaryDark}}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!--Senaste aktiviteter-->
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="{resx:Translate RecentActivities}" Style="{StaticResource SectionTitleLabel}" />

                        <CollectionView ItemsSource="{Binding RecentActivities}" SelectionMode="None" HeightRequest="{Binding RecentActivitiesHeight}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto" 
                                          ColumnSpacing="15" 
                                          Padding="0,10">

                                         <!--Ikon--> 
                                        <Label Grid.Column="0"
                                               Text="{Binding Icon}"
                                               FontSize="20"
                                               VerticalOptions="Center" />

                                         <!--Beskrivning--> 
                                        <StackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding Description}"
                                                   FontAttributes="Bold"
                                                   FontSize="14" />
                                            <Label Text="{Binding TimeText}"
                                                   Style="{StaticResource SecondaryLabel}"
                                                   FontSize="14" />
                                        </StackLayout>

                                         <!--Varaktighet med färg--> 
                                        <Label Grid.Column="2"
                                               Text="{Binding Duration}"
                                               FontSize="14"
                                               TextColor="{StaticResource ButtonPrimary}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                            <CollectionView.EmptyView>
                                <StackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="40,20" Spacing="10">
                                    <Label Text="{resx:Translate NoActivitiesIcon}" FontSize="32" HorizontalOptions="Center" Opacity="0.6" />
                                    <Label Text="{resx:Translate NoActivitiesTitle}"
                                           FontSize="16" FontAttributes="Bold"
                                           Style="{StaticResource SecondaryLabel}"
                                           HorizontalOptions="Center" />
                                    <Label Text="{resx:Translate NoActivitiesMessage}"
                                           Style="{StaticResource SecondaryLabel}"
                                           FontSize="14"
                                           HorizontalOptions="Center" />
                                </StackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                 <!--Dagens datum (längst ner)--> 
                <Label Text="{Binding TodayDate}"
                       Style="{StaticResource SecondaryLabel}"
                       FontSize="12"
                       HorizontalOptions="Center"
                       Margin="0,10,0,20" />

            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
