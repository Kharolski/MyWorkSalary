<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.HomePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Hem"
             BackgroundColor="{StaticResource AppBackground}">
    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30,20" VerticalOptions="Center">

            <!-- Vit kort-stil för innehållet -->
            <Frame BackgroundColor="{StaticResource CardBackground}"
                   CornerRadius="10"
                   HasShadow="True"
                   Padding="20">
                <VerticalStackLayout Spacing="15">
                    <Label x:Name="WelcomeLabel"
                           Text="My Work Salary"
                           FontSize="28"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />

                    <Label Text="Välkommen till din löneapp!"
                           FontSize="16"
                           TextColor="#666666"
                           HorizontalOptions="Center" />

                    <Button x:Name="SetupJobBtn"
                            Text="Skapa ditt första jobb"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            CornerRadius="8"
                            Clicked="OnSetupJobClicked"
                            HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
