<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.HomePage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Hem">
    <!-- BackgroundColor kommer från Page Style -->

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="30,20" VerticalOptions="Center">

            <!-- Välkomst-kort -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="15">
                    <Label Text="{Binding WelcomeText}"
                           Style="{StaticResource TitleLabel}" />

                    <!-- Visa när inget jobb finns -->
                    <StackLayout IsVisible="{Binding ShowSetupButton}">
                        <Label Text="Välkommen till din löneapp!"
                               Style="{StaticResource SecondaryLabel}"
                               HorizontalOptions="Center" />

                        <Button Text="Skapa ditt första jobb"
                                Command="{Binding SetupJobCommand}"
                                HorizontalOptions="Center" />
                    </StackLayout>

                    <!-- Visa när jobb finns -->
                    <StackLayout IsVisible="{Binding HasActiveJob}">
                        <Label Text="{Binding ActiveJob.Workplace}"
                               Style="{StaticResource SecondaryLabel}"
                               HorizontalOptions="Center" />

                        <Label Text="Vad vill du göra idag?"
                               FontSize="16"
                               HorizontalOptions="Center"
                               Margin="0,10,0,0" />
                    </StackLayout>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
