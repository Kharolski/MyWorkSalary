<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyWorkSalary.Views.Settings.AboutAppPage"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization"
             Title="{resx:Translate AboutApp}">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="20">

            <!-- App Icon -->
            <Image Source="appicon.png"
                   HeightRequest="100"
                   WidthRequest="100"
                   HorizontalOptions="Center" />

            <!-- App Name -->
            <Label Text="My Work Salary"
                   FontSize="26"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <!-- Version -->
            <Label Text="{Binding AppVersion}"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="{StaticResource SecondaryTextColor}" />

            <!-- Description -->
            <Label Text="{resx:Translate AboutAppDescription}"
                   FontSize="15"
                   HorizontalTextAlignment="Center"
                   TextColor="{StaticResource SecondaryTextColor}" />

            <!-- Developer -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="8" Padding="15">
                    <Label Text="{resx:Translate AboutDeveloper}" FontSize="16" />
                    <Label Text="{resx:Translate AboutContact}" FontSize="14" />
                </VerticalStackLayout>
            </Border>

            <!-- Privacy Policy -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="8" Padding="15">
                    <Label Text="{resx:Translate AboutPrivacyPolicy}" FontSize="16" />
                    <Label Text="{resx:Translate AboutPrivacyPolicyDescription}" FontSize="14" />
                </VerticalStackLayout>
            </Border>

            <!-- Developer Tools (endast för utveckling) -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="8" Padding="15,0,15,10">
                    <Grid ColumnDefinitions="*,Auto,*" Margin="0,10,0,10" VerticalOptions="Center">
                        <BoxView Grid.Column="0" HeightRequest="1" VerticalOptions="Center"
                                Color="{AppThemeBinding Light=#E0E0E0, Dark=#444444}" />

                        <Label Grid.Column="1" TextColor="Blue"
                               Text="Developer Tools"
                               FontSize="20"
                               FontAttributes="Bold"
                               Margin="12,0" />
                        <BoxView Grid.Column="2" HeightRequest="1" VerticalOptions="Center"
                                Color="{AppThemeBinding Light=#E0E0E0, Dark=#444444}" />
                    </Grid>

                    <Button Text="Aktivera Premium (test)" Clicked="OnActivatePremiumClicked" />

                    <Label Text="Prenumeration (test)" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="Red" />
                    <Grid ColumnDefinitions="*,*">
                        <Button Grid.Column="0" Margin="0,0,5,0" Text="Aktivera" Clicked="OnActivateSubscriptionClicked" />
                        <Button Grid.Column="1" Margin="5,0,0,0" Text="Avsluta" Clicked="OnCancelSubscriptionClicked" />
                    </Grid>

                    <Label Text="Rensa" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="Red" />
                    <Button Text="Rensa Premium-status" Clicked="OnClearPremiumClicked" />

                    <!-- Status feedback -->
                    <Label Text="{Binding PremiumDebugStatus}"
                           TextColor="Red"  Margin="0,10,0,0"
                           FontAttributes="Bold"
                           FontSize="14" />

                </VerticalStackLayout>
            </Border>


        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

