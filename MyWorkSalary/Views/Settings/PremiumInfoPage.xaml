<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyWorkSalary.Views.Settings.PremiumInfoPage"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization"
             Title="{resx:Translate Premium_Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Header -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="💎"
                       FontSize="48"
                       HorizontalOptions="Center" />

                <Label Text="{resx:Translate Premium_HeaderTitle}"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Label Text="{resx:Translate Premium_HeaderSubtitle}"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                               Dark={StaticResource TextSecondaryDark}}" />
            </VerticalStackLayout>

            <!-- Premium (engångsköp) -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding IsFreeUser}">
                <VerticalStackLayout Spacing="12">

                    <Label Text="{resx:Translate Premium_OneTime_Title}"
                           Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="{resx:Translate Premium_OneTime_Description}"
                           Style="{StaticResource TipsLabel}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="{resx:Translate Premium_Feature_UnlimitedJobs}" />
                        <Label Text="{resx:Translate Premium_Feature_OnCall}" />
                        <Label Text="{resx:Translate Premium_Feature_OBTemplates}" />
                        <Label Text="{resx:Translate Premium_Feature_Export}" />
                        <Label Text="{resx:Translate Premium_Feature_Inbeordring}" />
                    </VerticalStackLayout>

                    <Button Text="{resx:Translate Premium_BuyButton}"
                            BackgroundColor="{StaticResource ButtonPrimary}"
                            TextColor="White"
                            CornerRadius="8"
                            Padding="0,12"
                            Clicked="OnBuyPremiumClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- Har Premium (engångsköp) -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding HasPremium}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{resx:Translate Premium_Status_PremiumTitle}" FontSize="18" FontAttributes="Bold" />
                    <Label Text="{resx:Translate Premium_Status_PremiumDescription}" Style="{StaticResource TipsLabel}" />

                    <Label Text="{resx:Translate Premium_Status_ConvertedPremium}"
                           Style="{StaticResource TipsLabel}"
                           IsVisible="{Binding IsConvertedPremium}" />

                </VerticalStackLayout>
            </Border>

            <!-- Subscription -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding ShowSubscription}">
                <VerticalStackLayout Spacing="12">

                    <Label Text="{resx:Translate Premium_Subscription_Title}"
                           Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="{resx:Translate Premium_Subscription_Description}"
                           Style="{StaticResource TipsLabel}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="{resx:Translate Premium_Feature_AllPremium}" />
                        <Label Text="{resx:Translate Premium_Feature_Backup}" />
                        <Label Text="{resx:Translate Premium_Feature_FutureFeatures}" />
                        <Label Text="{resx:Translate Premium_Feature_Themes}" />
                    </VerticalStackLayout>

                    <Button Text="{resx:Translate Premium_SubscribeButton}"
                            BackgroundColor="{StaticResource ButtonPrimary}"
                            TextColor="White"
                            CornerRadius="8"
                            Padding="0,12"
                            Clicked="OnSubscribeClicked" />
                </VerticalStackLayout>
            </Border>

            <!-- Har Subscription -->
            <Border Style="{StaticResource CardBorder}" IsVisible="{Binding HasSubscription}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{resx:Translate Premium_Status_SubscriptionTitle}" FontSize="18" FontAttributes="Bold" />
                    <Label Text="{resx:Translate Premium_Status_SubscriptionDescription}" Style="{StaticResource TipsLabel}" />

                    <!-- Startdatum -->
                    <Label Text="{Binding SubscriptionStartFormatted}"
                           Style="{StaticResource TipsLabel}"
                           IsVisible="{Binding HasSubscription}" />

                    <!-- Slutdatum (om avslutad) -->
                    <Label Text="{Binding SubscriptionEndFormatted}"
                           Style="{StaticResource TipsLabel}"
                           IsVisible="{Binding SubscriptionEndText}" />

                    <Button Text="Avsluta prenumeration (Demo)"
                            BackgroundColor="Orange"
                            TextColor="White"
                            CornerRadius="8"
                            Padding="0,12"
                            Clicked="OnCancelSubscriptionClicked" />

                </VerticalStackLayout>
            </Border>

            <!-- Developer Tools (endast för utveckling) -->
            <Border Style="{StaticResource InfoBorder}" IsVisible="{Binding ShowDebugTools}">
                <VerticalStackLayout Spacing="8" Padding="15,0,15,10">
                    <Grid ColumnDefinitions="*,Auto,*" Margin="0,10,0,10" VerticalOptions="Center">
                        <BoxView Grid.Column="0" HeightRequest="1" VerticalOptions="Center"
                                Color="{AppThemeBinding Light=#E0E0E0, Dark=#444444}" />

                        <Label Grid.Column="1" TextColor="Blue"
                               Text="Developer Tools"
                               FontSize="20"
                               FontAttributes="Bold"
                               Margin="12,0" />
                        <BoxView Grid.Column="2" HeightRequest="1" VerticalOptions="Center"
                                Color="{AppThemeBinding Light=#E0E0E0, Dark=#444444}" />
                    </Grid>

                    <Label Text="Rensa" FontSize="16" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="Red" />
                    <Button Text="Rensa Premium-status" Clicked="OnClearPremiumClicked" />

                    <!-- Status feedback -->
                    <Label Text="{Binding PremiumDebugStatus}"
                           TextColor="Red"  Margin="0,10,0,0"
                           FontAttributes="Bold"
                           FontSize="14" />

                </VerticalStackLayout>
            </Border>
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>