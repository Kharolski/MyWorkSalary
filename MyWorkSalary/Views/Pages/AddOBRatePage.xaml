<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyWorkSalary.Views.Pages.AddOBRatePage"
             xmlns:resx="clr-namespace:MyWorkSalary.Resources.Resx"
             Title="{x:Static resx:Resources.OBRule_Title}">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Namn på OB-regel -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static resx:Resources.OBRule_Name_Label}"
                           Style="{StaticResource FieldTitleLabel}" />
                    <Entry Text="{Binding Name}"
                           Placeholder="{x:Static resx:Resources.OBRule_Name_Placeholder}"
                           FontSize="16"
                           Style="{StaticResource ThemedEntry}" />
                    <Label Text="{Binding NameError}" TextColor="Red" FontSize="12"
                            IsVisible="{Binding NameError, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Tider -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="15">
                    <Label Text="{x:Static resx:Resources.OBRule_TimeSection_Label}"
                           Style="{StaticResource FieldTitleLabel}" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <!-- Starttid -->
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="{x:Static resx:Resources.OBRule_From_Label}"
                                   FontSize="14" 
                                   Style="{StaticResource SecondaryLabel}" />
                            <TimePicker Time="{Binding StartTime}" 
                                       FontSize="16" Format="HH:mm"
                                       Style="{StaticResource ThemedTimePicker}" />
                        </VerticalStackLayout>

                        <!-- Sluttid -->
                        <VerticalStackLayout Grid.Column="1" Spacing="5">
                            <Label Text="{x:Static resx:Resources.OBRule_To_Label}"
                                   FontSize="14"
                                   Style="{StaticResource SecondaryLabel}" />
                            <TimePicker Time="{Binding EndTime}"
                                       FontSize="16" Format="HH:mm"
                                       Style="{StaticResource ThemedTimePicker}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Lön per timme -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static resx:Resources.OBRule_Rate_Label}"
                           Style="{StaticResource FieldTitleLabel}" />
                    <Entry Text="{Binding RatePerHour}"
                           Placeholder="{x:Static resx:Resources.OBRule_Rate_Placeholder}" Keyboard="Numeric" FontSize="16"
                           Style="{StaticResource ThemedEntry}" />
                    <Label Text="{x:Static resx:Resources.OBRule_Rate_Tip}"
                           Style="{StaticResource TipsLabel}" />
                    <Label Text="{Binding RateError}" TextColor="Red" FontSize="12"
                            IsVisible="{Binding RateError, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Kategori -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static resx:Resources.OBRule_Category_Label}"
                           Style="{StaticResource FieldTitleLabel}" />
                    <Picker ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding SelectedCategory}"
                            FontSize="16"
                            Style="{StaticResource ThemedPicker}" />
                    <Label Text="{Binding CategoryError}" TextColor="Red" FontSize="12" 
                            IsVisible="{Binding CategoryError, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Veckodagar -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="15">
                    <Label Text="{x:Static resx:Resources.OBRule_Days_Label}"
                           Style="{StaticResource FieldTitleLabel}" />

                    <Grid ColumnDefinitions="*,*" 
                          RowDefinitions="Auto,Auto,Auto,Auto, Auto" 
                          ColumnSpacing="10" 
                          RowSpacing="8">

                        <!-- Måndag -->
                        <StackLayout Grid.Row="0" Grid.Column="0" 
                                     Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding Monday}"
                                     Style="{StaticResource ThemedCheckBox}" />
                            <Label Text="{x:Static resx:Resources.OBRule_Monday}" Style="{StaticResource DayLabel}" />
                        </StackLayout>

                        <!-- Tisdag -->
                        <StackLayout Grid.Row="0" Grid.Column="1" 
                                     Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding Tuesday}"
                                     Style="{StaticResource ThemedCheckBox}" />
                            <Label Text="{x:Static resx:Resources.OBRule_Tuesday}" Style="{StaticResource DayLabel}" />
                        </StackLayout>

                        <!-- Onsdag -->
                        <StackLayout Grid.Row="1" Grid.Column="0" 
                                     Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding Wednesday}"
                                     Style="{StaticResource ThemedCheckBox}" />
                            <Label Text="{x:Static resx:Resources.OBRule_Wednesday}" Style="{StaticResource DayLabel}" />
                        </StackLayout>

                        <!-- Torsdag -->
                        <StackLayout Grid.Row="1" Grid.Column="1" 
                                     Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding Thursday}"
                                     Style="{StaticResource ThemedCheckBox}" />
                            <Label Text="{x:Static resx:Resources.OBRule_Thursday}" Style="{StaticResource DayLabel}" />
                        </StackLayout>

                        <!-- Fredag -->
                        <StackLayout Grid.Row="2" Grid.Column="0" 
                                     Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding Friday}"
                                     Style="{StaticResource ThemedCheckBox}" />
                            <Label Text="{x:Static resx:Resources.OBRule_Friday}" Style="{StaticResource DayLabel}" />
                        </StackLayout>

                        <!-- Lördag -->
                        <StackLayout Grid.Row="2" Grid.Column="1" 
                                     Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding Saturday}"
                                     Style="{StaticResource ThemedCheckBox}" />
                            <Label Text="{x:Static resx:Resources.OBRule_Saturday}" Style="{StaticResource DayLabel}" />
                        </StackLayout>

                        <!-- Söndag -->
                        <StackLayout Grid.Row="3" Grid.Column="0" 
                                     Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding Sunday}"
                                     Style="{StaticResource ThemedCheckBox}" />
                            <Label Text="{x:Static resx:Resources.OBRule_Sunday}" Style="{StaticResource DayLabel}" />
                        </StackLayout>

                        <!-- Helgdagar -->
                        <StackLayout Grid.Row="4" Grid.Column="0" 
                                     Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding Holidays}"
                                     Style="{StaticResource ThemedCheckBox}" />
                            <Label Text="{x:Static resx:Resources.OBRule_Holidays}" Style="{StaticResource DayLabel}" />
                        </StackLayout>

                        <!-- Storhelg -->
                        <StackLayout Grid.Row="4" Grid.Column="1"
                                    Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{Binding BigHolidays}"
                                    Style="{StaticResource ThemedCheckBox}" />
                            <Label Text="{x:Static resx:Resources.OBRule_BigHolidays}" Style="{StaticResource DayLabel}" />
                        </StackLayout>
                    </Grid>

                    <!-- Snabbknappar -->
                    <StackLayout Orientation="Horizontal" 
                                 Spacing="10" 
                                 HorizontalOptions="Center">

                        <Button Text="{x:Static resx:Resources.OBRule_SelectWeekdays}"
                                Command="{Binding SelectWeekdaysCommand}"
                                Style="{StaticResource WeekdaysButton}" />

                        <Button Text="{x:Static resx:Resources.OBRule_SelectWeekends}"
                                Command="{Binding SelectWeekendsCommand}"
                                Style="{StaticResource WeekendsButton}" />

                        <Button Text="{x:Static resx:Resources.OBRule_SelectAll}"
                                Command="{Binding SelectAllDaysCommand}"
                                Style="{StaticResource AllDaysButton}" />
                    </StackLayout>

                    <Label Text="{Binding DaysError}" TextColor="Red" FontSize="12"
                            IsVisible="{Binding DaysError, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                </VerticalStackLayout>
            </Border>

            <!-- Spara knapp -->
            <Button Text="{x:Static resx:Resources.OBRule_Save_Button}"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource SalaryPrimary}"
                    TextColor="{StaticResource White}"
                    CornerRadius="8"
                    Padding="0,15"
                    FontSize="16"
                    Margin="0,20,0,0" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
