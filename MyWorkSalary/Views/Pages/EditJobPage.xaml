<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.Pages.EditJobPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Redigera jobb">
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">
            <!-- Header -->
            <Label Text="✏️ Redigera jobb"
                   Style="{StaticResource TitleLabel}"
                   Margin="0,0,0,20" />

            <!-- Grundläggande info -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📋 Grundläggande information"
                           Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="Jobbtitel *"
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding JobTitle}"
                           Placeholder="t.ex. Undersköterska"
                           Style="{StaticResource ThemedEntry}" />

                    <Label Text="Arbetsplats *"
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding Workplace}"
                           Placeholder="t.ex. Ljungby Kommun"
                           Style="{StaticResource ThemedEntry}" />

                    <!-- Anställningsdatum -->
                    <Label Text="Anställningsdatum *" 
                           Style="{StaticResource SecondaryLabel}" />
                    <DatePicker Date="{Binding EmploymentStartDate}"
                                Style="{StaticResource ThemedDatePicker}"
                                Format="dddd d MMMM yyyy"/>

                    <Label Text="Anställningstyp"
                           Style="{StaticResource SecondaryLabel}" />
                    <Picker ItemsSource="{Binding EmploymentTypes}"
                            SelectedItem="{Binding SelectedEmploymentType}"
                            Style="{StaticResource ThemedPicker}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Lön -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="💰 Löneinformation"
                           Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="Lönetyp"
                           Style="{StaticResource SecondaryLabel}" />
                    <Picker ItemsSource="{Binding SalaryTypes}"
                            SelectedItem="{Binding SelectedSalaryType}"
                            Style="{StaticResource ThemedPicker}" />

                    <!-- Månadslön -->
                    <StackLayout IsVisible="{Binding IsMonthlySalary}">
                        <Label Text="Månadslön (kr)"
                               Style="{StaticResource SecondaryLabel}" />
                        <Entry Text="{Binding MonthlySalary}"
                               Keyboard="Numeric"
                               Placeholder="t.ex. 28500"
                               Style="{StaticResource ThemedEntry}" />
                    </StackLayout>

                    <!-- Timlön -->
                    <StackLayout IsVisible="{Binding IsHourlySalary}">
                        <Label Text="Timlön (kr)"
                               Style="{StaticResource SecondaryLabel}" />
                        <Entry Text="{Binding HourlyRate}"
                               Keyboard="Numeric"
                               Placeholder="t.ex. 185"
                               Style="{StaticResource ThemedEntry}" />
                    </StackLayout>

                    <Label Text="Förväntade timmar per månad"
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding ExpectedHoursPerMonth}"
                           Keyboard="Numeric"
                           Placeholder="t.ex. 165"
                           Style="{StaticResource ThemedEntry}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Semester -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🏖️ Semesterinformation" 
                           Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="Semesterdagar per år" 
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding VacationDaysPerYear}"
                           Keyboard="Numeric"
                           Placeholder="25"
                           Style="{StaticResource ThemedEntry}" />

                    <!-- Visa bara om anställning > 1 månad -->
                    <StackLayout IsVisible="{Binding ShowInitialVacationBalance}">
                        <Label Text="Sparade semesterdagar just nu" 
                               Style="{StaticResource SecondaryLabel}" />
                        <Entry Text="{Binding InitialVacationBalance}"
                               Keyboard="Numeric"
                               Placeholder="t.ex. 12.5"
                               Style="{StaticResource ThemedEntry}" />
                        <Label Text="💡 Ange dina sparade semesterdagar från senaste lönespec"
                               Style="{StaticResource TipsLabel}" />
                    </StackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Skatt -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="🏛️ Skatteinformation"
                           Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="Skattesats (%)"
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding TaxRate}"
                           Keyboard="Numeric"
                           Placeholder="t.ex. 33"
                           Style="{StaticResource ThemedEntry}" />

                    <Label Text="💡 Tips: Kolla din senaste lönespec för exakt skattesats"
                           Style="{StaticResource TipsLabel}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Knappar -->
            <StackLayout Orientation="Horizontal"
                         HorizontalOptions="FillAndExpand"
                         Spacing="10"
                         Margin="0,20,0,0">
                <Button Text="Avbryt"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalOptions="FillAndExpand" />
                <Button Text="💾 Spara ändringar"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource EditButton}"
                        HorizontalOptions="FillAndExpand" />
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
