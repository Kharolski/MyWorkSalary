<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.Pages.EditJobPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:MyWorkSalary.Resources.Resx"
             xmlns:loc="clr-namespace:MyWorkSalary.Helpers.Localization"
             Title="{x:Static resx:Resources.EditJob_Header}">
    
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">
            
            <!-- Grundläggande info -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static resx:Resources.BasicInfo_SectionTitle}"
                           Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="{x:Static resx:Resources.JobTitle_Label}"
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding JobTitle}"
                           Placeholder="{x:Static resx:Resources.JobTitle_Placeholder}"
                           Style="{StaticResource ThemedEntry}" />

                    <Label Text="{x:Static resx:Resources.Workplace_Label}"
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding Workplace}"
                           Placeholder="{x:Static resx:Resources.Workplace_Placeholder}"
                           Style="{StaticResource ThemedEntry}" />

                    <!-- Anställningsdatum -->
                    <Label Text="{x:Static resx:Resources.EmploymentDate_Label}"
                           Style="{StaticResource SecondaryLabel}" />
                    <DatePicker Date="{Binding EmploymentStartDate}"
                            Style="{StaticResource ThemedDatePicker}"
                            Format="{Binding DatePickerFormat, Source={x:Static loc:TranslationManager.Instance}}" />

                    <Label Text="{x:Static resx:Resources.EmploymentType_Label}"
                           Style="{StaticResource SecondaryLabel}" />
                    <Picker ItemsSource="{Binding EmploymentTypes}"
                            SelectedItem="{Binding SelectedEmploymentType}"
                            Style="{StaticResource ThemedPicker}" />

                    <!-- Land -->
                    <HorizontalStackLayout HorizontalOptions="Center">
                        <Label Text="{x:Static resx:Resources.Country_Label}"
                               Style="{StaticResource SecondaryLabel}" />
                        <Label Text="{Binding CountryDisplayName}" 
                               FontAttributes="Bold"
                               FontSize="16"
                               Margin="5,0,0,0" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Lön -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static resx:Resources.Salary_SectionTitle}"
               Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="{x:Static resx:Resources.SalaryType_Label}"
               Style="{StaticResource SecondaryLabel}" />
                    <Picker ItemsSource="{Binding SalaryTypes}"
                SelectedItem="{Binding SelectedSalaryType}"
                Style="{StaticResource ThemedPicker}" />

                    <!-- Månadslön + Valuta -->
                    <Grid IsVisible="{Binding IsMonthlySalary}" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <!-- Label + Entry -->
                            <ColumnDefinition Width="1*" />
                            <!-- Picker -->
                        </Grid.ColumnDefinitions>

                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{x:Static resx:Resources.MonthlySalary_Label}"
                                    Style="{StaticResource SecondaryLabel}" />
                            <Entry Text="{Binding MonthlySalary}"
                                   Keyboard="Numeric"
                                   Placeholder="{x:Static resx:Resources.MonthlySalary_Placeholder}"
                                   Style="{StaticResource ThemedEntry}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="{x:Static resx:Resources.Currency_Label}"
                                    Style="{StaticResource SecondaryLabel}" />
                            <Picker ItemsSource="{Binding AvailableCurrencies}"
                                    ItemDisplayBinding="{Binding DisplayName}"
                                    SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}"
                                    Style="{StaticResource ThemedPicker}" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Timlön + Valuta -->
                    <Grid IsVisible="{Binding IsHourlySalary}" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="{x:Static resx:Resources.HourlySalary_Label}"
                                Style="{StaticResource SecondaryLabel}" />
                            <Entry Text="{Binding HourlyRate}"
                               Keyboard="Numeric"
                               Placeholder="{x:Static resx:Resources.HourlySalary_Placeholder}"
                               Style="{StaticResource ThemedEntry}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="{x:Static resx:Resources.Currency_Label}"
                                Style="{StaticResource SecondaryLabel}" />
                            <Picker ItemsSource="{Binding AvailableCurrencies}"
                                ItemDisplayBinding="{Binding DisplayName}"
                                SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}"
                                Style="{StaticResource ThemedPicker}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Label Text="{x:Static resx:Resources.ExpectedHours_Label}"
                            Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding ExpectedHoursPerMonth}"
                           Keyboard="Numeric"
                           Placeholder="{x:Static resx:Resources.ExpectedHours_Placeholder}"
                           Style="{StaticResource ThemedEntry}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Semester -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static resx:Resources.Vacation_SectionTitle}"
                           Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="{x:Static resx:Resources.VacationDays_Label}" 
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding VacationDaysPerYear}"
                           Keyboard="Numeric"
                           Placeholder="25"
                           Style="{StaticResource ThemedEntry}" />

                    <!-- Visa bara om anställning > 1 månad -->
                    <StackLayout IsVisible="{Binding ShowInitialVacationBalance}">
                        <Label Text="{x:Static resx:Resources.InitialVacation_Label}" 
                               Style="{StaticResource SecondaryLabel}" />
                        <Entry Text="{Binding InitialVacationBalance}"
                               Keyboard="Numeric"
                               Placeholder="{x:Static resx:Resources.InitialVacation_Placeholder}"
                               Style="{StaticResource ThemedEntry}" />
                        <Label Text="{x:Static resx:Resources.Vacation_Tip}"
                               Style="{StaticResource TipsLabel}" />
                    </StackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Skatt -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static resx:Resources.Tax_SectionTitle}"
                           Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="{x:Static resx:Resources.TaxRate_Label}"
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding TaxRate}"
                           Keyboard="Numeric"
                           Placeholder="{x:Static resx:Resources.TaxRate_Placeholder}"
                           Style="{StaticResource ThemedEntry}" />

                    <Label Text="{x:Static resx:Resources.Tax_Tip}"
                           Style="{StaticResource TipsLabel}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Knappar -->
            <StackLayout Orientation="Horizontal"
                         HorizontalOptions="FillAndExpand"
                         Spacing="10"
                         Margin="0,20,0,0">
                <Button Text="{x:Static resx:Resources.Button_Cancel}"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalOptions="FillAndExpand" />
                <Button Text="{x:Static resx:Resources.Button_SaveChanges}"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource EditButton}"
                        HorizontalOptions="FillAndExpand" />
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
