<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyWorkSalary.Views.Pages.ShiftTypeView.SickLeaveFormView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization">

    <VerticalStackLayout Spacing="20">

        <!-- 🤒 Sjuktyp -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate Sick_Label_Type}"
                   Style="{StaticResource FieldLabel}" />
            <Picker ItemsSource="{Binding SickTypeDisplayNames}"
                    SelectedItem="{Binding SickTypeDisplayName}"
                    Style="{StaticResource ThemedPicker}"
                    Title="{resx:Translate Sick_Picker_Title}" />
        </VerticalStackLayout>

        <!-- 📝 Förklaring av vald sjuktyp -->
        <Frame Style="{StaticResource ActiveJobFrame}">
            <VerticalStackLayout Spacing="5">
                <Label Text="{resx:Translate Sick_Header}"
                       Style="{StaticResource ActiveJobTitleLabel}"
                       FontSize="14" />
                <Label Text="{Binding SickLeaveExplanation}"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />
            </VerticalStackLayout>
        </Frame>

        <!-- ⏰ Arbetstider (bara för delvis sjuk) -->
        <VerticalStackLayout Spacing="15" IsVisible="{Binding ShowPartialTimeFields}">

            <!-- Jobbat tid (bara för delvis sjuk) -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding ShowWorkedTimeFields}">
                <Label Text="{resx:Translate Sick_Label_WorkedTime}"
                       Style="{StaticResource FieldLabel}" />
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                    
                    <!-- Starttid jobbat -->
                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                        <Label Text="{resx:Translate From}" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <TimePicker Time="{Binding WorkedStartTime}"
                                    Style="{StaticResource ThemedTimePicker}"
                                    Format="HH:mm" />
                    </VerticalStackLayout>
                    
                    <!-- Separator -->
                    <Label Grid.Column="1"
                           Text="→"
                           FontSize="20"
                           VerticalOptions="Center"
                           TextColor="Gray" />
                    
                    <!-- Sluttid jobbat -->
                    <VerticalStackLayout Grid.Column="2" Spacing="3">
                        <Label Text="{resx:Translate To}" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <TimePicker Time="{Binding WorkedEndTime}"
                                    Style="{StaticResource ThemedTimePicker}"
                                    Format="HH:mm" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>

            <!-- Planerad tid (för både delvis sjuk OCH skulle jobbat) -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding ShowScheduledTimeFields}">
                <Label Text="{resx:Translate Sick_Label_ScheduledTime}"
                       Style="{StaticResource FieldLabel}" />
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                    
                    <!-- Starttid planerad -->
                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                        <Label Text="{resx:Translate From}" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <TimePicker Time="{Binding ScheduledStartTime}"
                                    Style="{StaticResource ThemedTimePicker}"
                                    Format="HH:mm" />
                    </VerticalStackLayout>
                    
                    <!-- Separator -->
                    <Label Grid.Column="1"
                           Text="→"
                           FontSize="20"
                           VerticalOptions="Center"
                           TextColor="Gray" />
                    
                    <!-- Sluttid planerad -->
                    <VerticalStackLayout Grid.Column="2" Spacing="3">
                        <Label Text="{resx:Translate To}" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <TimePicker Time="{Binding ScheduledEndTime}"
                                    Style="{StaticResource ThemedTimePicker}"
                                    Format="HH:mm" />
                    </VerticalStackLayout>
                </Grid>
                <Label Text="{resx:Translate Sick_Hint_ScheduledZero}"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                   Dark={StaticResource TextSecondaryDark}}"
                       Margin="0,5,0,0" />
            </VerticalStackLayout>

        </VerticalStackLayout>

        <!-- ⚠️ Validation meddelanden -->
        <ContentView IsVisible="{Binding HasValidationMessage}">
            <Label Text="{Binding ValidationMessage}"
                   FontSize="14"
                   Style="{StaticResource ValidationLabel}"
                   Margin="0,0,0,10" />
        </ContentView>
        
        <!-- 📝 Anteckningar -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate Sick_Label_Notes}"
                   Style="{StaticResource FieldLabel}" />
            <Editor Text="{Binding Notes}"
                    Placeholder="{resx:Translate Sick_Placeholder_Notes}"
                    Style="{StaticResource ThemedEditor}"
                    HeightRequest="80" />
        </VerticalStackLayout>

    </VerticalStackLayout>
</ContentView>
