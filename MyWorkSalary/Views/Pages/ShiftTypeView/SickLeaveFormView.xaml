<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyWorkSalary.Views.Pages.ShiftTypesView.SickLeaveFormView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Spacing="20">

        <!-- 🤒 Sjuktyp -->
        <VerticalStackLayout Spacing="5">
            <Label Text="🤒 Typ av sjukskrivning"
                   Style="{StaticResource FieldLabel}" />
            <Picker ItemsSource="{Binding SickTypeDisplayNames}"
                    SelectedItem="{Binding SickTypeDisplayName}"
                    Style="{StaticResource ThemedPicker}"
                    Title="Välj sjuktyp" />
        </VerticalStackLayout>

        <!-- 📝 Förklaring av vald sjuktyp -->
        <Frame Style="{StaticResource ActiveJobFrame}">
            <VerticalStackLayout Spacing="5">
                <Label Text="ℹ️ Information"
                       Style="{StaticResource ActiveJobTitleLabel}"
                       FontSize="14" />
                <Label Text="{Binding SickLeaveExplanation}"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />
            </VerticalStackLayout>
        </Frame>

        <!-- ⏰ Arbetstider (bara för delvis sjuk) -->
        <VerticalStackLayout Spacing="15" IsVisible="{Binding ShowPartialTimeFields}">

            <!-- Jobbat tid (bara för delvis sjuk) -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding ShowWorkedTimeFields}">
                <Label Text="🕐 Tid som jobbades"
                       Style="{StaticResource FieldLabel}" />
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                    
                    <!-- Starttid jobbat -->
                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                        <Label Text="Från" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <TimePicker Time="{Binding WorkedStartTime}"
                                    Style="{StaticResource ThemedTimePicker}"
                                    Format="HH:mm" />
                    </VerticalStackLayout>
                    
                    <!-- Separator -->
                    <Label Grid.Column="1"
                           Text="→"
                           FontSize="20"
                           VerticalOptions="Center"
                           TextColor="Gray" />
                    
                    <!-- Sluttid jobbat -->
                    <VerticalStackLayout Grid.Column="2" Spacing="3">
                        <Label Text="Till" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <TimePicker Time="{Binding WorkedEndTime}"
                                    Style="{StaticResource ThemedTimePicker}"
                                    Format="HH:mm" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>

            <!-- Planerad tid (för både delvis sjuk OCH skulle jobbat) -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding ShowScheduledTimeFields}">
                <Label Text="📋 Tid som skulle jobbats"
                       Style="{StaticResource FieldLabel}" />
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                    
                    <!-- Starttid planerad -->
                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                        <Label Text="Från" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <TimePicker Time="{Binding ScheduledStartTime}"
                                    Style="{StaticResource ThemedTimePicker}"
                                    Format="HH:mm" />
                    </VerticalStackLayout>
                    
                    <!-- Separator -->
                    <Label Grid.Column="1"
                           Text="→"
                           FontSize="20"
                           VerticalOptions="Center"
                           TextColor="Gray" />
                    
                    <!-- Sluttid planerad -->
                    <VerticalStackLayout Grid.Column="2" Spacing="3">
                        <Label Text="Till" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <TimePicker Time="{Binding ScheduledEndTime}"
                                    Style="{StaticResource ThemedTimePicker}"
                                    Format="HH:mm" />
                    </VerticalStackLayout>
                </Grid>
                <Label Text="💡 Ange den tid som skulle jobbats enligt schema"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                   Dark={StaticResource TextSecondaryDark}}"
                       Margin="0,5,0,0" />
            </VerticalStackLayout>

        </VerticalStackLayout>

        <!-- 💰 Beräknad ersättning -->
        <Frame Style="{StaticResource CalculationFrame}"
               IsVisible="{Binding ShowPayCalculation}">
            <VerticalStackLayout Spacing="8">
                <Label Text="💰 Sjukersättning"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />

                <!-- Karens info -->
                <Label Text="{Binding KarensInfo}"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />

                <!-- Total ersättning -->
                <Label Text="{Binding CalculatedPay, StringFormat='Total ersättning: {0:N0} kr'}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Success},
                                                   Dark={StaticResource Success}}" />
            </VerticalStackLayout>
        </Frame>

        <!-- ⚠️ Validation meddelanden -->
        <ContentView IsVisible="{Binding HasValidationMessage}">
            <Label Text="{Binding ValidationMessage}"
                   FontSize="14"
                   Style="{StaticResource ValidationLabel}"
                   Margin="0,0,0,10" />
        </ContentView>
        
        <!-- 📝 Anteckningar -->
        <VerticalStackLayout Spacing="5">
            <Label Text="📝 Anteckningar (valfritt)"
                   Style="{StaticResource FieldLabel}" />
            <Editor Text="{Binding Notes}"
                    Placeholder="T.ex. läkarintyg, symptom, återkomstdatum..."
                    Style="{StaticResource ThemedEditor}"
                    HeightRequest="80" />
        </VerticalStackLayout>

    </VerticalStackLayout>
</ContentView>
