<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyWorkSalary.Views.Pages.ShiftTypeView.VABFormView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization">
    
    <VerticalStackLayout Spacing="20">

        <!-- 🍼 VAB Förklaring -->
        <Frame Style="{StaticResource ActiveJobFrame}">
            <VerticalStackLayout Spacing="8">
                <Label Text="{resx:Translate VAB_Header}"
                       Style="{StaticResource ActiveJobTitleLabel}"
                       FontSize="16" />
                <Label Text="{Binding VABExplanationText}"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />
            </VerticalStackLayout>
        </Frame>

        <!-- 🕐 Timmar som skulle jobbats -->
        <VerticalStackLayout Spacing="5" IsVisible="{Binding ShowVABWorkingHours}">
            <Label Text="{resx:Translate VAB_Label_ScheduledHours}"
                   Style="{StaticResource FieldLabel}" />
            <Entry Text="{Binding ScheduledHours}"
                   Placeholder="{resx:Translate VAB_Placeholder_ScheduledHours}"
                   Keyboard="Numeric"
                   Style="{StaticResource ThemedEntry}" />
            <Label Text="{resx:Translate VAB_Hint_ScheduledZero}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                               Dark={StaticResource TextSecondaryDark}}" />
        </VerticalStackLayout>

        <!-- 💼 Timmar som faktiskt jobbades (NYTT FÄLT) -->
        <VerticalStackLayout Spacing="5" IsVisible="{Binding ShowVABWorkingHours}">
            <Label Text="{resx:Translate VAB_Label_WorkedHours}" Style="{StaticResource FieldLabel}" />
            <Entry Text="{Binding WorkedHours}"
                   Placeholder="{resx:Translate VAB_Placeholder_WorkedHours}"
                   Keyboard="Numeric"
                   Style="{StaticResource ThemedEntry}" />
            <Label Text="{resx:Translate VAB_Hint_WorkedZero}" 
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                               Dark={StaticResource TextSecondaryDark}}" />
        </VerticalStackLayout>

        <!-- 💰 Beräknad information -->
        <Frame Style="{StaticResource CalculationFrame}"
               IsVisible="{Binding ShowCalculation}">
            <VerticalStackLayout Spacing="8">
                <Label Text="{resx:Translate VAB_Info_Header}"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />

                <!-- Beräkningssammanfattning -->
                <Label Text="{Binding CalculationSummary}"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />

                <!-- Löneavdrag för fast anställda -->
                <Label Text="{Binding PayDeductionText}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Warning},
                                                   Dark={StaticResource Warning}}"
                       IsVisible="{Binding ShowPayDeduction}" />

                <!-- VAB-ersättning info -->
                <Label Text="{resx:Translate VAB_Info_Compensation}"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource Success},
                                                   Dark={StaticResource Success}}" />
            </VerticalStackLayout>
        </Frame>

        <!-- ⚠️ Validation meddelanden -->
        <ContentView IsVisible="{Binding HasValidationMessage}">
            <Label Text="{Binding ValidationMessage}"
                   FontSize="14"
                   Style="{StaticResource ValidationLabel}"
                   Margin="0,0,0,0" />
        </ContentView>

    </VerticalStackLayout>
</ContentView>
