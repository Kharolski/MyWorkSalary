<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization"
             x:Class="MyWorkSalary.Views.Pages.ShiftTypeView.RegularShiftFormView">
    <VerticalStackLayout Spacing="20">

        <!-- Arbetstid -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate RegularShift_WorkTime}" Style="{StaticResource FieldLabel}" />
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                <!-- Starttid -->
                <VerticalStackLayout Grid.Column="0" Spacing="3">
                    <Label Text="{resx:Translate RegularShift_From}" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                    <TimePicker Time="{Binding StartTime}" Style="{StaticResource ThemedTimePicker}" Format="HH:mm" />
                </VerticalStackLayout>
                <!-- Separator -->
                <Label Grid.Column="1" Text="→" FontSize="20" VerticalOptions="Center" TextColor="Gray" />
                <!-- Sluttid -->
                <VerticalStackLayout Grid.Column="2" Spacing="3">
                    <Label Text="{resx:Translate RegularShift_To}" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                    <TimePicker Time="{Binding EndTime}" Style="{StaticResource ThemedTimePicker}" Format="HH:mm" />
                </VerticalStackLayout>
            </Grid>
        </VerticalStackLayout>

        <!-- Rast -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate RegularShift_Break}" Style="{StaticResource FieldLabel}" />
            <Entry Text="{Binding BreakMinutes}" Placeholder="0" Keyboard="Numeric" Style="{StaticResource ThemedEntry}" />
            <Label Text="{Binding BreakSuggestionText}" FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
        </VerticalStackLayout>

        <!-- Automatisk helgdagsvisning -->
        <VerticalStackLayout Spacing="8">
            <Label Text="{resx:Translate RegularShift_DayType}" FontSize="14" FontAttributes="Bold" />

            <!-- Röd dag indikator -->
            <HorizontalStackLayout Spacing="10">
                <Border BackgroundColor="{Binding IsHoliday, Converter={StaticResource BoolToColorConverter}}"
                StrokeShape="RoundRectangle" StrokeThickness="0"
                Padding="8,4">
                    <Label Text="{resx:Translate RegularShift_Holiday}" TextColor="White" FontSize="12" FontAttributes="Bold" />
                </Border>
                <Label Text="Automatiskt identifierad" 
               VerticalOptions="Center" FontSize="11" 
               TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                         Dark={StaticResource TextSecondaryDark}}" 
               IsVisible="{Binding IsHoliday}" />
            </HorizontalStackLayout>

            <!-- Storhelg indikator -->
            <HorizontalStackLayout Spacing="10" Margin="20,0,0,0" IsVisible="{Binding IsHoliday}">
                <Border BackgroundColor="{Binding IsBigHoliday, Converter={StaticResource BoolToColorConverter}}"
                StrokeShape="RoundRectangle" StrokeThickness="0"
                Padding="8,4">
                    <Label Text="{resx:Translate RegularShift_BigHoliday}" TextColor="White" FontSize="12" FontAttributes="Bold" />
                </Border>
                <Label Text="Storhelg" 
               VerticalOptions="Center" FontSize="11" 
               TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                         Dark={StaticResource TextSecondaryDark}}" 
               IsVisible="{Binding IsBigHoliday}" />
            </HorizontalStackLayout>

            <!-- Hjälptext -->
            <Label Text="Helgdagar identifieras automatiskt baserat på jobbets land"
           FontSize="11" Margin="0,4,0,0"
           TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                       Dark={StaticResource TextSecondaryDark}}" />
        </VerticalStackLayout>

        <!-- Helgdag / Storhelg / Inbeordring -->
        <Border Style="{StaticResource CardBorder}">
            
            <VerticalStackLayout Spacing="10">
                <Label Text="{resx:Translate RegularShift_DayType}" Style="{StaticResource FieldLabel}" />

                <!-- Extra pass -->
                <HorizontalStackLayout Spacing="10" IsEnabled="{Binding IsPremiumOrSubscriber}">
                    <CheckBox IsChecked="{Binding IsExtraShift}" IsEnabled="{Binding IsPremiumOrSubscriber}" />
                    <Label Text="{resx:Translate RegularShift_ExtraShift}" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Extra Shift låst för gratisanvändare -->
                <VerticalStackLayout IsVisible="{Binding IsFreeUser}" Margin="0,0,0,0" Spacing="6">
                    <Label Text="{resx:Translate ExtraShift_Locked_Description}" FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                       Dark={StaticResource TextSecondaryDark}}" />

                    <Button Text="{resx:Translate ViewUpgradeOptions}"
                            Command="{Binding OpenPremiumPageCommand}"
                            BackgroundColor="{StaticResource ButtonPrimary}"
                            TextColor="White"
                            CornerRadius="8"
                            Padding="0,8" />
                </VerticalStackLayout>

                <!-- hjälptext  -->
                <Label Text="{resx:Translate RegularShift_ExtraShiftHint}" IsVisible="{Binding IsPremiumOrSubscriber}"
                       FontSize="12"
                       Margin="34,0,0,0"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                   Dark={StaticResource TextSecondaryDark}}" />

                <!-- Separator och Debug checkboxar -->
                <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,6" IsVisible="{Binding ShowDebugCheckboxes}" />

                <!-- Röd dag -->
                <HorizontalStackLayout Spacing="10" IsVisible="{Binding ShowDebugCheckboxes}">
                    <CheckBox IsChecked="{Binding IsHoliday}" />
                    <Label Text="{resx:Translate RegularShift_Holiday}" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Storhelg -->
                <HorizontalStackLayout Spacing="10" IsVisible="{Binding ShowDebugCheckboxes}">
                    <CheckBox IsChecked="{Binding IsBigHoliday}" IsEnabled="{Binding IsHoliday}" />
                    <Label Text="{resx:Translate RegularShift_BigHoliday}" VerticalOptions="Center"
                           Opacity="{Binding IsHoliday, Converter={StaticResource BoolToOpacityConverter}}" />
                </HorizontalStackLayout>

                <!-- hjälptext  -->
                <Label Text="{resx:Translate RegularShift_DayTypeHint}" IsVisible="{Binding ShowDebugCheckboxes}"
                       FontSize="12" Margin="34,0,0,0"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                   Dark={StaticResource TextSecondaryDark}}" />
                
            </VerticalStackLayout>
        </Border>

        <!-- Anteckningar -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate RegularShift_Notes}" Style="{StaticResource FieldLabel}" />
            <Editor Text="{Binding Notes}" Placeholder="{resx:Translate RegularShift_NotesPlaceholder}" Style="{StaticResource ThemedEditor}" HeightRequest="80" />
        </VerticalStackLayout>

        <!-- Beräknad information -->
        <Border Style="{StaticResource CalculationBorder}"
                IsVisible="{Binding ShowCalculation}">
            <VerticalStackLayout Spacing="5">
                <Label Text="{resx:Translate RegularShift_Calculation}"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />
                        <Label Text="{Binding CalculationSummary}"
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />
                <Label Text="{resx:Translate RegularShift_CalculationNote}"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                Dark={StaticResource TextSecondaryDark}}" /> 
            </VerticalStackLayout>
        </Border>

    </VerticalStackLayout>
</ContentView>