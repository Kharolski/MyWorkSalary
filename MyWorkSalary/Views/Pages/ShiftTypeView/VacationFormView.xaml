<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyWorkSalary.Views.Pages.ShiftTypeView.VacationFormView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <VerticalStackLayout Spacing="20">

        <!-- 🏖️ Semestertyp -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate Vacation_Label_Type}" Style="{StaticResource FieldLabel}" />
            <Picker ItemsSource="{Binding VacationTypeDisplayNames}"
                    SelectedItem="{Binding VacationTypeDisplayName}"
                    Style="{StaticResource ThemedPicker}"
                    Title="{resx:Translate Vacation_Picker_Title}" />
            
        </VerticalStackLayout>

        <!-- 🧮 Semesterkvot - BARA för betald -->
        <VerticalStackLayout Spacing="5" IsVisible="{Binding IsPaidVacation}">
            <Label Text="{resx:Translate Vacation_Label_Ratio}" Style="{StaticResource FieldLabel}" />
            <Entry Text="{Binding SemesterKvot}"
                   Placeholder="1.0"
                   Keyboard="Numeric"
                   Style="{StaticResource ThemedEntry}" />
            <Label Text="{resx:Translate Vacation_Ratio_Hint}" 
                   FontSize="12"
                    TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                    Dark={StaticResource TextSecondaryDark}}" />
        </VerticalStackLayout>
        
        <!-- ⏰ Planerade arbetstimmar - BARA för obetald -->
        <VerticalStackLayout Spacing="5" IsVisible="{Binding IsUnpaidVacation}">
            <Label Text="{resx:Translate Vacation_Label_PlannedHours}" Style="{StaticResource FieldLabel}" />
            <Entry Text="{Binding PlannedWorkHours}"
                   Placeholder="8.0"
                   Keyboard="Numeric"
                   Style="{StaticResource ThemedEntry}" />
            <Label Text="{resx:Translate Vacation_Hours_Hint}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                   Dark={StaticResource TextSecondaryDark}}" />
        </VerticalStackLayout>

        <!-- 📝 Information -->
        <Frame Style="{StaticResource ActiveJobFrame}">
            <VerticalStackLayout Spacing="8">
                <Label Text="{resx:Translate Vacation_Info_Title}" 
                       Style="{StaticResource ActiveJobTitleLabel}" 
                       FontSize="14" />

                <Label Text="{Binding EmploymentTypeInfo}" 
                       FontSize="12" 
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                            Dark={StaticResource White}}" />

                <!-- 📊 Återstående semesterdagar -->
                <Label Text="{Binding RemainingVacationText}"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource SalaryPrimary}, 
                                                  Dark={StaticResource White}}"
                       IsVisible="{Binding ShowRemainingDays}" />

                <!-- info -->
                <Label Text="{resx:Translate Vacation_Info_OneDayRegistered}" 
                       FontSize="12" 
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                            Dark={StaticResource White}}" />

                <Label Text="{resx:Translate Vacation_Info_SalaryCalculated}" 
                       FontSize="12" 
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                            Dark={StaticResource White}}" />
            </VerticalStackLayout>
        </Frame>

        <!-- 🏠 Obetald ledighet info -->
        <Frame Style="{StaticResource InfoFrame}" 
               IsVisible="{Binding ShowUnpaidVacationFields}">
            <VerticalStackLayout Spacing="5">
                <Label Text="{resx:Translate Vacation_Unpaid_Title}" 
                       FontSize="14" 
                       FontAttributes="Bold" />
                <Label Text="{resx:Translate Vacation_Unpaid_Info}"
                       FontSize="13" />
            </VerticalStackLayout>
        </Frame>

        <!-- ⚠️ Validation -->
        <ContentView IsVisible="{Binding HasValidationMessage}">
            <Label Text="{Binding ValidationMessage}" 
                   Style="{StaticResource ValidationLabel}" />
        </ContentView>

    </VerticalStackLayout>
</ContentView>
