<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyWorkSalary.Views.Pages.ShiftTypeView.OnCallFormView"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization">
    
    <VerticalStackLayout Spacing="20">
        <!-- 📞 Förklaring av jour -->
        <Frame Style="{StaticResource ActiveJobFrame}">
            <VerticalStackLayout Spacing="5">
                <Label Text="{resx:Translate OnCall_InfoTitle}"
                       Style="{StaticResource ActiveJobTitleLabel}"
                       FontSize="14" />
                <Label Text="{Binding OnCallExplanationText}"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />
            </VerticalStackLayout>
        </Frame>

        <!-- 🕐 Jourtid -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate OnCall_StandbyTime}"
                   Style="{StaticResource FieldLabel}" />
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                <!-- Starttid -->
                <VerticalStackLayout Grid.Column="0" Spacing="3">
                    <Label Text="{resx:Translate From}" 
                           FontSize="12" 
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" 
                           HorizontalOptions="Center" />
                    <TimePicker Time="{Binding StandbyStartTime}"
                                Style="{StaticResource ThemedTimePicker}"
                                Format="HH:mm" />
                </VerticalStackLayout>
                <!-- Separator -->
                <Label Grid.Column="1"
                       Text="→"
                       FontSize="20"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
                <!-- Sluttid -->
                <VerticalStackLayout Grid.Column="2" Spacing="3">
                    <Label Text="{resx:Translate To}" 
                           FontSize="12" 
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" 
                           HorizontalOptions="Center" />
                    <TimePicker Time="{Binding StandbyEndTime}"
                                Style="{StaticResource ThemedTimePicker}"
                                Format="HH:mm" />
                </VerticalStackLayout>
            </Grid>
            <!-- Jourtimmar info -->
            <Label Text="{Binding StandbyHoursText}"
                   FontSize="12"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource SalaryPrimary},
                                               Dark={StaticResource SalaryPrimaryDark}}"
                   HorizontalOptions="Center"
                   Margin="0,5,0,0" />
            <Label Text="{resx:Translate OnCall_StandbyTip}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                               Dark={StaticResource TextSecondaryDark}}"
                   Margin="0,5,0,0" />
        </VerticalStackLayout>

        <!-- ⚡ Aktiv arbetstid -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate OnCall_ActiveHours}"
                   Style="{StaticResource FieldLabel}" />
            <Entry Text="{Binding ActiveHours}"
                   Placeholder="0"
                   Keyboard="Numeric"
                   Style="{StaticResource ThemedEntry}" />
            <Label Text="{resx:Translate OnCall_ActiveHoursTip}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                               Dark={StaticResource TextSecondaryDark}}" />
            <!-- Aktiv arbetstid info -->
            <Frame Style="{StaticResource InfoFrame}"
                    IsVisible="{Binding ShowActiveHoursInfo}">
                <VerticalStackLayout Spacing="3">
                    <Label Text="{resx:Translate OnCall_ActiveHoursRegistered}"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                       Dark={StaticResource White}}" />
                    <Label Text="{resx:Translate OnCall_ActiveHoursInfo}"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                       Dark={StaticResource TextSecondaryDark}}" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <!-- 💰 Jourersättning -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate OnCall_Rate}"
                   Style="{StaticResource FieldLabel}" />
            <Entry Text="{Binding OnCallRate}"
                   Placeholder="40"
                   Keyboard="Numeric"
                   Style="{StaticResource ThemedEntry}" />
            <Label Text="{Binding RateTipText}"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                               Dark={StaticResource TextSecondaryDark}}" />
        </VerticalStackLayout>

        <!-- 📊 Preliminär beräkning -->
        <Frame Style="{StaticResource CalculationFrame}"  IsVisible="{Binding ShowCalculation}">
            <VerticalStackLayout Spacing="8">

                <!-- Rubrik -->
                <Label Text="{resx:Translate OnCall_CalculationTitle}"
               FontSize="16"
               FontAttributes="Bold"
               TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                           Dark={StaticResource White}}" />

                <!-- Detaljerad breakdown -->
                <Label Text="{Binding CalculationSummary}"
               FontSize="13"
               TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                           Dark={StaticResource White}}" />

                <!-- Total ersättning -->
                <Label Text="{Binding TotalEstimateText}"
               FontSize="14"
               FontAttributes="Bold"
               TextColor="{StaticResource Success}" />

                <!-- OB-notis -->
                <Label Text="{resx:Translate OnCall_OBNotice}"
               FontSize="11"
               TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                           Dark={StaticResource TextSecondaryDark}}" />

            </VerticalStackLayout>
        </Frame>

        <!-- ⚠️ Validation meddelanden -->
        <ContentView IsVisible="{Binding HasValidationMessage}">
            <Label Text="{Binding ValidationMessage}"
                   FontSize="14"
                   TextColor="{StaticResource Error}"
                   FontAttributes="Bold"
                   Margin="0,0,0,10" />
        </ContentView>

        <!-- 📝 Anteckningar -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate OnCall_Notes}"
                   Style="{StaticResource FieldLabel}" />
            <Editor Text="{Binding Notes}"
                    Placeholder="{resx:Translate OnCall_NotesPlaceholder}"
                    Style="{StaticResource ThemedEditor}"
                    HeightRequest="80" />
        </VerticalStackLayout>
    </VerticalStackLayout>
</ContentView>