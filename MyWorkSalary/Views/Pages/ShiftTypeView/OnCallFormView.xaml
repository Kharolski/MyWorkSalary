<?xml version="1.0" encoding="utf-8" ?>
<ContentView x:Class="MyWorkSalary.Views.Pages.ShiftTypeView.OnCallFormView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization">

    <VerticalStackLayout Spacing="20">

        <!-- 📞 Förklaring -->
        <Frame Style="{StaticResource ActiveJobFrame}">
            <VerticalStackLayout Spacing="5">
                <Label Text="{resx:Translate OnCall_InfoTitle}"
                       Style="{StaticResource ActiveJobTitleLabel}"
                       FontSize="14" />
                <Label Text="{Binding OnCallExplanationText}"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />
            </VerticalStackLayout>
        </Frame>

        <!-- 🕐 Standby-tid -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate OnCall_StandbyTime}" Style="{StaticResource FieldLabel}" />

            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0" Spacing="3">
                    <Label Text="{resx:Translate From}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                       Dark={StaticResource TextSecondaryDark}}"
                           HorizontalOptions="Center" />
                    <TimePicker Time="{Binding StandbyStartTime}"
                                Style="{StaticResource ThemedTimePicker}"
                                Format="HH:mm" />
                </VerticalStackLayout>

                <Label Grid.Column="1"
                       Text="→"
                       FontSize="20"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                   Dark={StaticResource TextSecondaryDark}}" />

                <VerticalStackLayout Grid.Column="2" Spacing="3">
                    <Label Text="{resx:Translate To}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                       Dark={StaticResource TextSecondaryDark}}"
                           HorizontalOptions="Center" />
                    <TimePicker Time="{Binding StandbyEndTime}"
                                Style="{StaticResource ThemedTimePicker}"
                                Format="HH:mm" />
                </VerticalStackLayout>
            </Grid>

        </VerticalStackLayout>

        <!-- ⚡ Aktiv tid -->
        <VerticalStackLayout Spacing="6">
            <Label Text="{resx:Translate OnCall_ActiveTime}" Style="{StaticResource FieldLabel}" />

            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                <VerticalStackLayout Grid.Column="0" Spacing="3">
                    <Label Text="{resx:Translate From}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                       Dark={StaticResource TextSecondaryDark}}"
                   HorizontalOptions="Center" />
                    <TimePicker Time="{Binding NewCalloutStart}"
                                Format="HH:mm"
                                Style="{StaticResource ThemedTimePicker}" />
                </VerticalStackLayout>

                <Label Grid.Column="1"
                       Text="→"
                       FontSize="20"
                       VerticalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                   Dark={StaticResource TextSecondaryDark}}" />

                <VerticalStackLayout Grid.Column="2" Spacing="3">
                    <Label Text="{resx:Translate To}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                       Dark={StaticResource TextSecondaryDark}}"
                           HorizontalOptions="Center" />
                    <TimePicker Time="{Binding NewCalloutEnd}"
                                Format="HH:mm"
                                Style="{StaticResource ThemedTimePicker}" />
                </VerticalStackLayout>
            </Grid>

            <Editor Text="{Binding NewCalloutNotes}"
                    Placeholder="{resx:Translate OnCall_ActiveNotesPlaceholder}"
                    Style="{StaticResource ThemedEditor}"
                    HeightRequest="70" />

            <Button Text="{resx:Translate OnCall_AddActiveTime}"
                    Command="{Binding AddCalloutCommand}"
                    Style="{StaticResource EditButton}"
                    IsEnabled="{Binding CanAddCallout}"
                    Opacity="{Binding CanAddCallout, Converter={StaticResource BoolToOpacityConverter}}"
                    Padding="12,8"
                    HorizontalOptions="End" />
        </VerticalStackLayout>

        <!-- 📌 Tillagda aktiva tider -->
        <Frame Style="{StaticResource CardFrame}">
            <VerticalStackLayout Spacing="10">
                <Label Text="{resx:Translate OnCall_ActiveTimesListTitle}" Style="{StaticResource SectionTitleLabel}" />

                <Label Text="{resx:Translate OnCall_CalloutsTip}"
                        FontSize="12"
                        Style="{StaticResource TipsLabel}"
                        LineBreakMode="WordWrap" />

                <StackLayout IsVisible="{Binding HasNoCallouts}" Spacing="6" Margin="0,4">
                    <Label Text="📌" FontSize="28" HorizontalOptions="Center"/>
                    <Label Text="{resx:Translate OnCall_NoCallouts}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           Style="{StaticResource NoItemsLabel}" />
                </StackLayout>

                <CollectionView ItemsSource="{Binding Callouts}" IsVisible="{Binding HasCallouts}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource OBRuleFrame}">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">

                                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                                        <Label Text="{Binding TimeRangeText}"
                                               FontAttributes="Bold"
                                               FontSize="14" />

                                        <Label Text="{Binding HoursText}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                                           Dark={StaticResource TextSecondaryDark}}" />

                                        <Label Text="{Binding Notes}"
                                               IsVisible="{Binding HasNotes}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                                           Dark={StaticResource TextSecondaryDark}}" />
                                    </VerticalStackLayout>

                                    <Button Grid.Column="1"
                                            Text="🗑️"
                                            Command="{Binding Source={x:Reference Root}, Path=BindingContext.DeleteCalloutCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Transparent"
                                            Padding="8"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </Frame>

        <!-- ✅ Jour – Totals (timmar) -->
        <Frame Style="{StaticResource InfoFrame}">
            <VerticalStackLayout Spacing="6">
                <Label Text="{resx:Translate OnCall_TotalsTitle}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />

                <Label Text="{Binding OnCallTotalsText}"
                       FontSize="13"
                       TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                   Dark={StaticResource White}}" />

                <Label Text="{resx:Translate OnCall_TotalsHint}"
                       FontSize="11"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                   Dark={StaticResource TextSecondaryDark}}" />
            </VerticalStackLayout>
        </Frame>

        <!-- ⚠️ Validation -->
        <ContentView IsVisible="{Binding HasValidationMessage}">
            <Label Text="{Binding ValidationMessage}"
                   FontSize="14"
                   TextColor="{StaticResource Error}"
                   FontAttributes="Bold"
                   Margin="0,0,0,10" />
        </ContentView>

        <!-- 📝 Anteckningar -->
        <VerticalStackLayout Spacing="5">
            <Label Text="{resx:Translate OnCall_Notes}"
                   Style="{StaticResource FieldLabel}" />
            <Editor Text="{Binding Notes}"
                    Placeholder="{resx:Translate OnCall_NotesPlaceholder}"
                    Style="{StaticResource ThemedEditor}"
                    HeightRequest="80" />
        </VerticalStackLayout>

    </VerticalStackLayout>
</ContentView>