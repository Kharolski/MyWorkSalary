<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.Pages.AddJobPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:MyWorkSalary.Resources.Resx"
             Title="{x:Static resx:Resources.AddJobPage_Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">

            <!-- Grundläggande info -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static resx:Resources.AddJobPage_BasicInfo}"
                           Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="{x:Static resx:Resources.AddJobPage_JobTitle}"
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding JobTitle}"
                           Placeholder="{x:Static resx:Resources.AddJobPage_JobTitle_Placeholder}"
                           Style="{StaticResource ThemedEntry}" />
                    <Label Text="{Binding JobTitleError}" TextColor="Red" FontSize="12"
                           IsVisible="{Binding JobTitleError, Converter={StaticResource StringNotNullOrEmptyConverter}}" />

                    <Label Text="{x:Static resx:Resources.AddJobPage_Workplace}"
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding Workplace}"
                           Placeholder="{x:Static resx:Resources.AddJobPage_Workplace_Placeholder}"
                           Style="{StaticResource ThemedEntry}" />
                    <Label Text="{Binding WorkplaceError}" TextColor="Red" FontSize="12"
                           IsVisible="{Binding WorkplaceError, Converter={StaticResource StringNotNullOrEmptyConverter}}" />

                    <Label Text="{x:Static resx:Resources.AddJobPage_EmploymentDate}"
                           Style="{StaticResource SecondaryLabel}" />
                    <DatePicker Date="{Binding EmploymentStartDate}" 
                                Style="{StaticResource ThemedDatePicker}"
                                Format="dddd d MMMM yyyy"/>

                    <Label Text="{x:Static resx:Resources.AddJobPage_EmploymentType}"
                           Style="{StaticResource SecondaryLabel}" />
                    <Picker ItemsSource="{Binding EmploymentTypes}"
                            SelectedItem="{Binding SelectedEmploymentType}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            Style="{StaticResource ThemedPicker}" />

                    <Label Text="{x:Static resx:Resources.AddJobPage_Country}"
                           Style="{StaticResource SecondaryLabel}" />
                    <Picker ItemsSource="{Binding Countries}"
                            SelectedItem="{Binding SelectedCountry, Mode=TwoWay}"
                            ItemDisplayBinding="{Binding DisplayName}" />
                    <Label Text="{x:Static resx:Resources.AddJobPage_CountryTip}"
                           Style="{StaticResource TipsLabel}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Lön -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static resx:Resources.AddJobPage_SalarySection}"
                        Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="{x:Static resx:Resources.AddJobPage_SalaryType}"
                        Style="{StaticResource SecondaryLabel}" />
                    <Picker ItemsSource="{Binding SalaryTypes}"
                        SelectedItem="{Binding SelectedSalaryType}"
                            ItemDisplayBinding="{Binding DisplayName}"
                        Style="{StaticResource ThemedPicker}" />

                    <!-- Månadslön + Valuta -->
                    <StackLayout IsVisible="{Binding IsMonthlySalary}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{x:Static resx:Resources.AddJobPage_MonthlySalary}"
                           Style="{StaticResource SecondaryLabel}" />
                                <Entry Text="{Binding MonthlySalary}"
                           Keyboard="Numeric"
                           Placeholder="28500"
                           Style="{StaticResource ThemedEntry}" />
                                <Label Text="{Binding MonthlySalaryError}" TextColor="Red" FontSize="12"
                           IsVisible="{Binding MonthlySalaryError, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="{x:Static resx:Resources.AddJobPage_Currency}"
                           Style="{StaticResource SecondaryLabel}" />
                                <Picker ItemsSource="{Binding AvailableCurrencies}"
                            SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            Style="{StaticResource ThemedPicker}" />
                                <Label Text="{x:Static resx:Resources.AddJobPage_CurrencyTip}"
                           Style="{StaticResource TipsLabel}" />
                            </VerticalStackLayout>
                        </Grid>
                    </StackLayout>

                    <!-- Timlön + Valuta -->
                    <StackLayout IsVisible="{Binding IsHourlySalary}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{x:Static resx:Resources.AddJobPage_HourlyRate}"
                           Style="{StaticResource SecondaryLabel}" />
                                <Entry Text="{Binding HourlyRate}"
                           Keyboard="Numeric"
                           Placeholder="185"
                           Style="{StaticResource ThemedEntry}" />
                                <Label Text="{Binding HourlyRateError}" TextColor="Red" FontSize="12"
                           IsVisible="{Binding HourlyRateError, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="{x:Static resx:Resources.AddJobPage_Currency}"
                           Style="{StaticResource SecondaryLabel}" />
                                <Picker ItemsSource="{Binding AvailableCurrencies}"
                            SelectedItem="{Binding SelectedCurrency, Mode=TwoWay}"
                            ItemDisplayBinding="{Binding DisplayName}"
                            Style="{StaticResource ThemedPicker}" />
                                <Label Text="{x:Static resx:Resources.AddJobPage_CurrencyTip}"
                           Style="{StaticResource TipsLabel}" />
                            </VerticalStackLayout>
                        </Grid>
                    </StackLayout>

                    <Label Text="{x:Static resx:Resources.AddJobPage_ExpectedHours}"
               Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding ExpectedHoursPerMonth}"
               Keyboard="Numeric"
               Placeholder="160"
               Style="{StaticResource ThemedEntry}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Semester -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static resx:Resources.AddJobPage_VacationSection}"
                           Style="{StaticResource SectionTitleLabel}" />

                    <!-- Visas bara om man är fastanställd -->
                    <StackLayout IsVisible="{Binding IsPermanentEmployment}">
                        <Label Text="{x:Static resx:Resources.AddJobPage_VacationDays}"
                               Style="{StaticResource SecondaryLabel}" />
                        <Entry Text="{Binding VacationDaysPerYear}"
                               Keyboard="Numeric"
                               Placeholder="25"
                               Style="{StaticResource ThemedEntry}" />
                    </StackLayout>

                    <!-- Visa bara om anställning > 1 månad -->
                    <StackLayout IsVisible="{Binding ShowInitialVacationBalance}">
                        <Label Text="{x:Static resx:Resources.AddJobPage_SavedVacation}"
                               Style="{StaticResource SecondaryLabel}" />
                        <Entry Text="{Binding InitialVacationBalance}"
                               Keyboard="Numeric"
                               Placeholder="12.5"
                               Style="{StaticResource ThemedEntry}" />
                        <Label Text="{x:Static resx:Resources.AddJobPage_SavedVacationTip}"
                               Style="{StaticResource TipsLabel}" />
                    </StackLayout>

                    <!-- Info för timanställda -->
                    <StackLayout IsVisible="{Binding IsTemporaryEmployment}">
                        <Label Text="{x:Static resx:Resources.AddJobPage_TemporaryInfo}"
                               Style="{StaticResource TipsLabel}"
                               LineBreakMode="WordWrap" />
                    </StackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Skatt -->
            <Frame Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{x:Static resx:Resources.AddJobPage_TaxSection}"
                           Style="{StaticResource SectionTitleLabel}" />

                    <Label Text="{x:Static resx:Resources.AddJobPage_TaxRate}"
                           Style="{StaticResource SecondaryLabel}" />
                    <Entry Text="{Binding TaxRate}"
                           Keyboard="Numeric"
                           Placeholder="33"
                           Style="{StaticResource ThemedEntry}" />

                    <Label Text="{x:Static resx:Resources.AddJobPage_TaxTip}"
                           Style="{StaticResource TipsLabel}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Knappar -->
            <StackLayout Orientation="Horizontal"
                         HorizontalOptions="FillAndExpand"
                         Spacing="10"
                         Margin="0,20,0,0">

                <Button Text="{x:Static resx:Resources.Cancel}"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalOptions="FillAndExpand" />

                <Button Text="{x:Static resx:Resources.Save}"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ButtonAdd}"
                        HorizontalOptions="FillAndExpand" />
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
