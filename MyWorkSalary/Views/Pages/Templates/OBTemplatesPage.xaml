<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyWorkSalary.Views.Pages.Templates.OBTemplatesPage"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization"
             xmlns:converters="clr-namespace:MyWorkSalary.Helpers.Converters"
             Title="{resx:Translate OBTemplates_Title}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Info -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{resx:Translate OBTemplates_InfoTitle}" 
                           Style="{StaticResource SectionTitleLabel}" />
                    <Label Text="{resx:Translate OBTemplates_InfoText}"
                           Style="{StaticResource TipsLabel}"
                           FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <!-- Välj mall -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{resx:Translate OBTemplates_ChooseTemplate}"
                           Style="{StaticResource SectionTitleLabel}" />

                    <CollectionView ItemsSource="{Binding TemplateGroups}"
                                    IsGrouped="True"
                                    SelectedItem="{Binding SelectedTemplate}"
                                    SelectionMode="None">

                        <!-- Grupp-rubrik -->
                        <CollectionView.GroupHeaderTemplate>
                            <DataTemplate>
                                <Label Text="{Binding GroupTitle}"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       Margin="0,10,0,4" />
                            </DataTemplate>
                        </CollectionView.GroupHeaderTemplate>

                        <!-- Mall-item -->
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12" Margin="0,4" StrokeThickness="0" StrokeShape="RoundRectangle 10">

                                    <!-- Background with MultiBinding -->
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource SelectedTemplateBackgroundConverter}">
                                            <Binding Path="." />
                                            <Binding Path="BindingContext.SelectedTemplate" Source="{RelativeSource AncestorType={x:Type ContentPage}}" />
                                        </MultiBinding>
                                    </Border.Background>

                                    <!-- Tap gesture -->
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectTemplateCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <!-- Content -->
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="14">
                                            <Label.TextColor>
                                                <MultiBinding Converter="{StaticResource SelectedTemplateTextColorConverter}">
                                                    <Binding Path="." />
                                                    <Binding Path="BindingContext.SelectedTemplate" Source="{RelativeSource AncestorType={x:Type ContentPage}}" />
                                                </MultiBinding>
                                            </Label.TextColor>
                                        </Label>

                                        <Label Text="{Binding Description}" Style="{StaticResource OBInfoLabel}" />
                                    </VerticalStackLayout>

                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Förhandsvisa regler -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{resx:Translate OBTemplates_Preview}"
                           Style="{StaticResource SectionTitleLabel}" />
                    <Label Text="{resx:Translate OBTemplates_AmountsNote}"
                           Style="{StaticResource NoItemsLabel}"
                           FontSize="12" IsVisible="{Binding HasSelectedTemplate}" />

                    <CollectionView ItemsSource="{Binding PreviewRules}"
                                    SelectionMode="None"
                                    EmptyView="{resx:Translate OBTemplates_SelectToPreview}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource OBRuleBorder}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Name}"
                                                   FontAttributes="Bold"
                                                   FontSize="14" />
                                            <Label Text="{Binding PreviewText}"
                                                   FontSize="12"
                                                   Style="{StaticResource HelpLabel}" />
                                        </StackLayout>
                                        <Label Grid.Column="1"
                                               Text="{Binding RateDisplayText}"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>

            <!-- Actions -->
            <VerticalStackLayout Spacing="8">
                <Button Text="{resx:Translate OBTemplates_AddButton}"
                        Command="{Binding AddTemplateCommand}"
                        BackgroundColor="{StaticResource ButtonPrimary}"
                        TextColor="{StaticResource White}"
                        CornerRadius="8"
                        Padding="0,15"
                        IsEnabled="{Binding HasSelectedTemplate}" />

                <!-- Om du öppnar denna sida i “ersätt-läge” -->
                <Button Text="{resx:Translate OBTemplates_ReplaceButton}"
                        Command="{Binding ReplaceTemplateCommand}"
                        BackgroundColor="{StaticResource ButtonCancel}"
                        TextColor="{StaticResource White}"
                        CornerRadius="8"
                        Padding="0,15"
                        IsVisible="{Binding IsReplaceMode}"
                        IsEnabled="{Binding HasSelectedTemplate}" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>