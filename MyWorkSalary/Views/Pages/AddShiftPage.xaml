<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.Pages.AddShiftPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:MyWorkSalary.Helpers.Localization"
             xmlns:shifttypes="clr-namespace:MyWorkSalary.Views.Pages.ShiftTypeView"
             Title="{resx:Translate AddShift_Title}">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            <!-- Aktivt jobb info -->
            <Frame Style="{StaticResource ActiveJobFrame}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="{resx:Translate Job_Label}"
                           Style="{StaticResource ActiveJobTitleLabel}"
                           FontSize="14" />
                    <Label Text="{Binding ActiveJobTitle}"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                       Dark={StaticResource White}}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Datum -->
            <VerticalStackLayout Spacing="5">
                <Label Text="{resx:Translate Date_Label}"
                       Style="{StaticResource FieldLabel}" />
                <DatePicker Date="{Binding SelectedDate}"
                            Style="{StaticResource ThemedDatePicker}"
                            Format="dddd d MMMM yyyy" />
            </VerticalStackLayout>

            <!-- Passtyp -->
            <VerticalStackLayout Spacing="5">
                <Label Text="{resx:Translate ShiftType_Label}"
                       Style="{StaticResource FieldLabel}" />
                <Picker ItemsSource="{Binding ShiftTypeDisplayNames}"
                        SelectedItem="{Binding SelectedShiftTypeDisplay}"
                        Style="{StaticResource ThemedPicker}"
                        Title="{resx:Translate SelectShiftType_Placeholder}" />
            </VerticalStackLayout>

            <!-- 🤒 SJUKSKRIVNING FORM -->
            <ContentView IsVisible="{Binding ShowSickLeaveForm}">
                <shifttypes:SickLeaveFormView BindingContext="{Binding SickLeaveVM}" />
            </ContentView>

            <!-- 🍼 VAB FORM -->
            <ContentView IsVisible="{Binding ShowVABForm}">
                <shifttypes:VABFormView BindingContext="{Binding VABVM}" />
            </ContentView>

            <!-- 📞 ONCALL/JOUR FORM - LÄGG TILL DENNA -->
            <ContentView IsVisible="{Binding ShowOnCallForm}">
                <shifttypes:OnCallFormView BindingContext="{Binding OnCallVM}" />
            </ContentView>

            <!-- 🏖️ VACATION FORM (antar att du redan har denna) -->
            <ContentView IsVisible="{Binding ShowVacationForm}">
                <shifttypes:VacationFormView BindingContext="{Binding VacationVM}" />
            </ContentView>

            <!-- REGULAR SHIFT FORM -->
            <ContentView IsVisible="{Binding ShowGeneralForm}">
                <shifttypes:RegularShiftFormView BindingContext="{Binding RegularShiftVM}" />
            </ContentView>

            <!-- Knappar -->
            <StackLayout Orientation="Horizontal"
                         Spacing="10"
                         HorizontalOptions="FillAndExpand"
                         Margin="0,20,0,0">
                <!-- Avbryt -->
                <Button Text="{resx:Translate Button_Cancel}"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="0,15"
                        HorizontalOptions="FillAndExpand" />
                <!-- Spara -->
                <Button Text="{resx:Translate Button_SaveShift}"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{StaticResource ButtonPrimary}"
                        TextColor="{StaticResource White}"
                        CornerRadius="8"
                        Padding="0,15"
                        HorizontalOptions="FillAndExpand"
                        IsEnabled="{Binding CanSave}" />
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
