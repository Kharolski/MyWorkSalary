<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.Pages.AddShiftPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Lägg till pass">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            <!-- Header -->
            <Label Text="📝 Nytt arbetspass"
                   Style="{StaticResource TitleLabel}"
                   Margin="0,0,0,10" />

            <!-- Aktivt jobb info -->
            <Frame Style="{StaticResource ActiveJobFrame}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="📋 Jobb"
                           Style="{StaticResource ActiveJobTitleLabel}"
                           FontSize="14" />
                    <Label Text="{Binding ActiveJobTitle}"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                       Dark={StaticResource White}}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Datum -->
            <VerticalStackLayout Spacing="5">
                <Label Text="📅 Datum"
                       Style="{StaticResource FieldLabel}" />
                <DatePicker Date="{Binding SelectedDate}"
                            Style="{StaticResource ThemedDatePicker}"
                            Format="dddd d MMMM yyyy" />
            </VerticalStackLayout>

            <!-- Passtyp -->
            <VerticalStackLayout Spacing="5">
                <Label Text="📋 Typ av pass"
                       Style="{StaticResource FieldLabel}" />
                <Picker ItemsSource="{Binding ShiftTypeDisplayNames}"
                        SelectedItem="{Binding SelectedShiftTypeDisplay}"
                        Style="{StaticResource ThemedPicker}"
                        Title="Välj passtyp" />
            </VerticalStackLayout>

            <!-- Tider på samma rad - döljs för semester/sjuk -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding ShowTimeFields}">
                <Label Text="🕐 Arbetstid"
                       Style="{StaticResource FieldLabel}" />
                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="10">
                    <!-- Starttid -->
                    <VerticalStackLayout Grid.Column="0" Spacing="3">
                        <Label Text="Från" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <TimePicker Time="{Binding StartTime}"
                                    Style="{StaticResource ThemedTimePicker}"
                                    Format="HH:mm" />
                    </VerticalStackLayout>

                    <!-- Separator -->
                    <Label Grid.Column="1" 
                           Text="→" 
                           FontSize="20" 
                           VerticalOptions="Center"
                           TextColor="Gray" />

                    <!-- Sluttid -->
                    <VerticalStackLayout Grid.Column="2" Spacing="3">
                        <Label Text="Till" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <TimePicker Time="{Binding EndTime}"
                                    Style="{StaticResource ThemedTimePicker}"
                                    Format="HH:mm" />
                    </VerticalStackLayout>
                </Grid>

                <Label Text="💡 Tips: Om passet går över midnatt kommer sluttiden att räknas som nästa dag"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                   Dark={StaticResource TextSecondaryDark}}"
                       Margin="0,5,0,0" />
            </VerticalStackLayout>

            <!-- Antal dagar - visas för semester/sjuk -->
            <VerticalStackLayout Spacing="5" IsVisible="{Binding ShowDaysField}">
                <Label Text="📊 Antal dagar"
                       Style="{StaticResource FieldLabel}" />
                <Entry Text="{Binding NumberOfDays}"
                       Placeholder="Ange antal dagar"
                       Keyboard="Numeric"
                       Style="{StaticResource ThemedEntry}" />
                <Label Text="💡 Ange hur många dagar denna period gäller"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary},
                                                   Dark={StaticResource TextSecondaryDark}}" />
            </VerticalStackLayout>

            <!-- Anteckningar (valfritt) -->
            <VerticalStackLayout Spacing="5">
                <Label Text="📝 Anteckningar (valfritt)"
                       Style="{StaticResource FieldLabel}" />
                <Editor Text="{Binding Notes}"
                        Placeholder="T.ex. övertid, speciella omständigheter..."
                        Style="{StaticResource ThemedEditor}"
                        HeightRequest="80" />
            </VerticalStackLayout>

            <!-- Beräknad information -->
            <Frame Style="{StaticResource CalculationFrame}"
                   IsVisible="{Binding ShowCalculation}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="📊 Beräkning"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                       Dark={StaticResource White}}" />
                    <Label Text="{Binding CalculationSummary}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary},
                                                       Dark={StaticResource White}}" />
                    <Label Text="{Binding CalculatedPay, StringFormat='Beräknad lön: {0:C}'}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource Success},
                                                       Dark={StaticResource Success}}"
                           IsVisible="{Binding ShowPay}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Knappar -->
            <StackLayout Orientation="Horizontal"
                         Spacing="10"
                         HorizontalOptions="FillAndExpand"
                         Margin="0,20,0,0">
                <!-- Avbryt -->
                <Button Text="Avbryt"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="0,15"
                        HorizontalOptions="FillAndExpand" />
                <!-- Spara -->
                <Button Text="💾 Spara pass"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{StaticResource ButtonPrimary}"
                        TextColor="{StaticResource White}"
                        CornerRadius="8"
                        Padding="0,15"
                        HorizontalOptions="FillAndExpand"
                        IsEnabled="{Binding CanSave}" />
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
