<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.Pages.AddShiftPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Lägg till pass">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Header -->
            <Label Text="📝 Nytt arbetspass"
                   Style="{StaticResource TitleLabel}"
                   Margin="0,0,0,10" />

            <!-- Aktivt jobb info -->
            <Frame Style="{StaticResource ActiveJobFrame}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="📋 Jobb"
                           Style="{StaticResource ActiveJobTitleLabel}"
                           FontSize="14" />
                    <Label Text="{Binding ActiveJobTitle}"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                                      Dark={StaticResource White}}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Datum -->
            <VerticalStackLayout Spacing="5">
                <Label Text="📅 Datum"
                       Style="{StaticResource FieldLabel}" />
                <DatePicker Date="{Binding SelectedDate}"
                            Style="{StaticResource ThemedDatePicker}"
                            Format="dddd d MMMM yyyy" />
            </VerticalStackLayout>

            <!-- Starttid -->
            <VerticalStackLayout Spacing="5">
                <Label Text="🕐 Starttid"
                       Style="{StaticResource FieldLabel}" />
                <TimePicker Time="{Binding StartTime}"
                            Style="{StaticResource ThemedTimePicker}"
                            Format="HH:mm" />
            </VerticalStackLayout>

            <!-- Sluttid -->
            <VerticalStackLayout Spacing="5">
                <Label Text="🕐 Sluttid"
                       Style="{StaticResource FieldLabel}" />
                <TimePicker Time="{Binding EndTime}"
                            Style="{StaticResource ThemedTimePicker}"
                            Format="HH:mm" />
                <Label Text="💡 Tips: Om passet går över midnatt kommer sluttiden att räknas som nästa dag"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource TextSecondary}, 
                                                  Dark={StaticResource TextSecondaryDark}}"
                       Margin="0,5,0,0" />
            </VerticalStackLayout>

            <!-- Passtyp -->
            <VerticalStackLayout Spacing="5">
                <Label Text="📋 Typ av pass"
                       Style="{StaticResource FieldLabel}" />
                <Picker ItemsSource="{Binding ShiftTypes}"
                        SelectedItem="{Binding SelectedShiftType}"
                        Style="{StaticResource ThemedPicker}"
                        Title="Välj passtyp" />
            </VerticalStackLayout>

            <!-- Anteckningar (valfritt) -->
            <VerticalStackLayout Spacing="5">
                <Label Text="📝 Anteckningar (valfritt)"
                       Style="{StaticResource FieldLabel}" />
                <Editor Text="{Binding Notes}"
                        Placeholder="T.ex. övertid, speciella omständigheter..."
                        Style="{StaticResource ThemedEditor}"
                        HeightRequest="80" />
            </VerticalStackLayout>

            <!-- Beräknad information -->
            <Frame Style="{StaticResource CalculationFrame}"
                   IsVisible="{Binding ShowCalculation}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="📊 Beräkning"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                                      Dark={StaticResource White}}" />
                    <Label Text="{Binding CalculatedHours, StringFormat='Totalt: {0:F1} timmar'}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                                      Dark={StaticResource White}}" />
                    <Label Text="{Binding CalculatedPay, StringFormat='Beräknad lön: {0:C}'}"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource Success}, 
                                                      Dark={StaticResource Success}}"
                           IsVisible="{Binding ShowPay}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Knappar -->
            <StackLayout Orientation="Horizontal"
                         Spacing="10"
                         HorizontalOptions="FillAndExpand"
                         Margin="0,20,0,0">

                <!-- Avbryt -->
                <Button Text="Avbryt"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="0,15"
                        HorizontalOptions="FillAndExpand" />

                <!-- Spara -->
                <Button Text="💾 Spara pass"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{StaticResource SalaryPrimary}"
                        TextColor="{StaticResource White}"
                        CornerRadius="8"
                        Padding="0,15"
                        HorizontalOptions="FillAndExpand"
                        IsEnabled="{Binding CanSave}" />
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
