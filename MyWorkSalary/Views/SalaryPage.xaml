<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.SalaryPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Månads lönerapport">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20,10">

            <!-- ===================== -->
            <!-- 🚫 INGET AKTIVT JOBB -->
            <!-- ===================== -->
            <Frame
                Style="{StaticResource CardFrame}"
                IsVisible="{Binding HasActiveJob, Converter={StaticResource InvertedBoolConverter}}">
                <Label
                    Text="Ingen lönerapport än – skapa ett jobb först."
                    Style="{StaticResource SecondaryLabel}"
                    HorizontalOptions="Center" />
            </Frame>

            <!-- ===================== -->
            <!-- 🟦 KORT 1: RESULTAT -->
            <!-- ===================== -->
            <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding HasActiveJob}">

                <!-- Swipe på hela kortet -->
                <Frame.GestureRecognizers>
                    <SwipeGestureRecognizer Direction="Right" Command="{Binding PrevMonthCommand}" />
                    <SwipeGestureRecognizer Direction="Left"  Command="{Binding NextMonthCommand}" />
                </Frame.GestureRecognizers>

                <Grid ColumnDefinitions="60,*,60" HorizontalOptions="FillAndExpand" VerticalOptions="Center">

                    <!-- Vänster TOUCH-ZON -->
                    <Grid Grid.Column="0" HorizontalOptions="Fill" VerticalOptions="Fill" BackgroundColor="Transparent">

                        <Label Text="◀"
                               FontSize="22"
                               VerticalOptions="Center"
                               HorizontalOptions="Start"
                               IsEnabled="{Binding CanGoPrevMonth}"
                               Opacity="{Binding CanGoPrevMonth, Converter={StaticResource BoolToOpacityConverter}}" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PrevMonthCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <!-- Innehåll i mitten -->
                    <VerticalStackLayout Grid.Column="1"
                             Spacing="8"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">

                        <Label Text="💰" FontSize="28" HorizontalOptions="Center" />

                        <Label Text="{Binding MonthlySalaryText}"
                               FontSize="28"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource ActiveJobBlue}" />

                        <Label Text="{Binding CurrentMonthYearText}"
                               FontSize="14"
                               FontAttributes="Italic"
                               HorizontalOptions="Center"
                               Opacity="0.7"
                               TextColor="{AppThemeBinding Light={StaticResource SalaryNeutralLight},
                                                          Dark={StaticResource SalaryNeutralDark}}" />

                        <Label Text="{Binding HoursSummaryText}"
                               FontSize="15"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               Margin="0,4,0,0"
                               TextColor="{Binding HoursSummaryColor, Converter={StaticResource AmountToColorConverter}}" />
                    </VerticalStackLayout>

                    <!-- Höger TOUCH-ZON -->
                    <Grid Grid.Column="2" HorizontalOptions="Fill" VerticalOptions="Fill" BackgroundColor="Transparent">

                        <Label Text="▶"
                               FontSize="22"
                               VerticalOptions="Center"
                               HorizontalOptions="End"
                               IsEnabled="{Binding CanGoNextMonth}"
                               Opacity="{Binding CanGoNextMonth, Converter={StaticResource BoolToOpacityConverter}}" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NextMonthCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                </Grid>
            </Frame>

            <!-- ===================== -->
            <!-- 🟩 KORT 2: SAMMANFATTNING -->
            <!-- ===================== -->
            <Frame
                Style="{StaticResource CardFrame}"
                IsVisible="{Binding HasActiveJob}">
                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="📊 Sammanfattning"
                        Style="{StaticResource SectionTitleLabel}" />

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto, Auto" RowSpacing="8">

                        <!-- Rad 1: Lön -->
                        <Label Text="Grundlön" />
                        <Label Text="{Binding BaseSalaryText}" Grid.Column="1" FontAttributes="Bold" TextColor="Green" />

                        <!-- Rad 2: Arbetade timmar -->
                        <Label Text="Arbetade timmar" Grid.Row="1" />
                        <Label Text="{Binding TotalHoursText}" Grid.Row="1" Grid.Column="1" 
                               TextColor="{Binding HoursSummaryColor, Converter={StaticResource AmountToColorConverter}}"/>

                        <!-- Rad 3: OB-ersättning -->
                        <Label Text="OB-ersättning" Grid.Row="2" />
                        <Label Text="{Binding ObPayText}"
                                Grid.Row="2"
                                Grid.Column="1"
                                FontAttributes="Bold"
                                TextColor="Green" />

                        <!-- Rad 4: Skatt -->
                        <Label Text="Skatt" Grid.Row="3" />
                        <Label Text="{Binding TaxText}" Grid.Row="3" Grid.Column="1" TextColor="Gray" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,6" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Totalt utbetalt" FontAttributes="Bold" />
                        <Label Text="{Binding MonthlySalaryText}" Grid.Column="1" FontAttributes="Bold" />
                    </Grid>

                </VerticalStackLayout>
            </Frame>

            <!-- ===================== -->
            <!-- 🌙 KORT 3: OB-DETALJER (EXPANDERBAR) -->
            <!-- ===================== -->
            <Frame
                Style="{StaticResource CardFrame}"
                IsVisible="{Binding HasActiveJob}">

                <VerticalStackLayout Spacing="10">

                    <!-- Header (klickbar) -->
                    <Grid ColumnDefinitions="40,*,Auto,Auto" Padding="5">
                        <Label Text="🌙" FontSize="20" VerticalOptions="Center" />

                        <Label
                            Text="{Binding TotalObHoursText, StringFormat='OB: {0} h'}"
                            Grid.Column="1"
                            FontAttributes="Bold"
                            VerticalOptions="Center" />

                        <Label
                            Text="{Binding ObPayText}"
                            Grid.Column="2"
                            FontAttributes="Bold"
                            TextColor="Green"
                            VerticalOptions="Center" />

                        <Label
                            Text="{Binding ObCardChevronIcon}"
                            Grid.Column="3"
                            FontSize="18"
                            VerticalOptions="Center" />

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleObCardCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <!-- Expand -->
                    <StackLayout
                        IsVisible="{Binding IsObExpanded}"
                        Spacing="6">

                        <Label
                            Text="OB avser arbete föregående månad"
                            FontSize="12"
                            TextColor="Gray"
                            FontAttributes="Italic"
                            HorizontalOptions="Center" />

                        <CollectionView ItemsSource="{Binding ObDetails}">
                            <CollectionView.EmptyView>
                                <Label
                                    Text="Inga OB-timmar registrerade denna månad."
                                    TextColor="Gray"
                                    FontAttributes="Italic"
                                    HorizontalOptions="Center" />
                            </CollectionView.EmptyView>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                                        <Label Text="{Binding Date, StringFormat='{0:dd/MM}'}" />
                                        <Label Text="{Binding CategoryName}" Grid.Column="1" />
                                        <Label Text="{Binding Hours, StringFormat='{0:0.##} h'}" Grid.Column="2" />
                                        <Label Text="{Binding Pay, StringFormat='{0:C}'}" Grid.Column="3" TextColor="Green" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label FontAttributes="Bold">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Total OB-ersättning: " />
                                    <Span Text="{Binding ObPayText}" TextColor="Green" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                    </StackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- ===================== -->
            <!-- 👤 KORT 4: FRÅNVARO & BALANS (EXPANDERBAR) -->
            <!-- ===================== -->
            <Frame
                Style="{StaticResource CardFrame}"
                IsVisible="{Binding HasActiveJob}"> 

                <VerticalStackLayout Spacing="10">

                    <!-- 🔹 HEADER (klickbar) -->
                    <Grid ColumnDefinitions="40,*,Auto" Padding="5">
                        <!-- Ikon -->
                        <Label
                            Text="👤"
                            FontSize="20"
                            VerticalOptions="Center" />

                        <!-- Titel + snabb info -->
                        <HorizontalStackLayout Grid.Column="1" Spacing="10">
                            <Label
                                Text="Frånvaro och balans"
                                FontAttributes="Bold"
                                VerticalOptions="Center" />

                            <!-- Visa viktigaste direkt -->
                            <Label
                                Text="{Binding FlexBalanceText}"
                                TextColor="Gray"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <!-- Chevron -->
                        <Label
                            Text="{Binding BalanceChevronIcon}"
                            Grid.Column="2"
                            FontSize="18"
                            VerticalOptions="Center"
                            HorizontalOptions="End" />

                        <!-- Klick -->
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleBalanceCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <!-- 🔹 EXPANDERAT INNEHÅLL -->
                    <StackLayout
                        IsVisible="{Binding IsBalanceExpanded}"
                        Spacing="8"
                        Padding="5,5,5,0">

                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              RowSpacing="6">

                            <Label Text="⏱ Flexsaldo" />
                            <Label
                                Text="{Binding FlexBalanceText}"
                                Grid.Column="1" />

                            <Label Text="🤒 Sjukdagar" Grid.Row="1" />
                            <Label
                                Text="{Binding SickDaysText}"
                                Grid.Row="1"
                                Grid.Column="1" />

                            <Label Text="🌴 Semester" Grid.Row="2" />
                            <Label
                                Text="{Binding VacationDaysText}"
                                Grid.Row="2"
                                Grid.Column="1" />

                            <Label Text="👶 VAB" Grid.Row="3" />
                            <Label
                                Text="{Binding VabDaysText}"
                                Grid.Row="3"
                                Grid.Column="1" />

                            <Label Text="🧭 Jour" Grid.Row="4" />
                            <Label
                                Text="{Binding JourText}"
                                Grid.Row="4"
                                Grid.Column="1" />
                        </Grid>
                    </StackLayout>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>