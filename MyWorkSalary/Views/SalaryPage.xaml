<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.SalaryPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Månads lönerapport">
    <VerticalStackLayout Spacing="20" Padding="20,10" VerticalOptions="Start">

        <!-- visas bara när det INTE finns ett aktivt jobb -->
        <StackLayout IsVisible="{Binding HasActiveJob, Converter={StaticResource InvertedBoolConverter}}"
             Spacing="5">
            <Frame Style="{StaticResource CardFrame}">
                <Label Text="Ingen lönerapport än – skapa ett jobb först."
               Style="{StaticResource SecondaryLabel}"
               HorizontalOptions="Center" />
            </Frame>
        </StackLayout>

        <!-- visas när det FINNS ett aktivt jobb -->
        <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding HasActiveJob}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Lön denna månad" FontSize="20" FontAttributes="Bold" Style="{StaticResource SectionTitleLabel}" />
                <Label Text="{Binding MonthlySalaryText}" FontSize="20" FontAttributes="Bold"
                       TextColor="{StaticResource ActiveJobBlue}" />
                <Label Text="{Binding HoursSummaryText}" FontSize="14" />
            </VerticalStackLayout>
        </Frame>

        <!-- Statistics Section -->
        <Frame Style="{StaticResource CardFrame}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Beräkning Statistik" FontSize="20" FontAttributes="Bold" Style="{StaticResource SectionTitleLabel}" />
                
                <!-- Grundlön -->
                <Label Text="{Binding BaseSalaryText}" FontSize="14" />
                <Label Text="{Binding TotalHoursText}" FontSize="14" />
                
                <Label Text="{Binding TotalObHoursText}" FontSize="14" />
                <Label Text="{Binding ObPayText}" FontSize="14" />

                <!--Ska går genom att dem ska visa rätt data-->
                <Label Text="{Binding FlexBalanceText}" FontSize="14" />
                <Label Text="{Binding SickDaysText}" FontSize="14" />
                <Label Text="{Binding VacationDaysText}" FontSize="14" />
                <Label Text="{Binding VabDaysText}" FontSize="14" />
                <Label Text="{Binding JourText}" FontSize="14" />
            </VerticalStackLayout>
        </Frame>

        

        <!-- Monthly Reports -->
        <!--<Frame Style="{StaticResource CardFrame}">
            <VerticalStackLayout Spacing="10">
