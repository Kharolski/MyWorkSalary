<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="MyWorkSalary.Views.SalaryPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Månads lönerapport">
    <VerticalStackLayout Spacing="20" Padding="20,10" VerticalOptions="Start">

        <!-- visas bara när det INTE finns ett aktivt jobb -->
        <StackLayout IsVisible="{Binding HasActiveJob, Converter={StaticResource InvertedBoolConverter}}"
             Spacing="5">
            <Frame Style="{StaticResource CardFrame}">
                <Label Text="Ingen lönerapport än – skapa ett jobb först."
               Style="{StaticResource SecondaryLabel}"
               HorizontalOptions="Center" />
            </Frame>
        </StackLayout>

        <!-- visas när det FINNS ett aktivt jobb -->
        <Frame Style="{StaticResource CardFrame}" IsVisible="{Binding HasActiveJob}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Lön denna månad" FontSize="20" FontAttributes="Bold" Style="{StaticResource SectionTitleLabel}" />
                <Label Text="{Binding MonthlySalaryText}" FontSize="20" FontAttributes="Bold"
                       TextColor="{StaticResource ActiveJobBlue}" />
                <Label Text="{Binding HoursSummaryText}" FontSize="14" />
            </VerticalStackLayout>
        </Frame>

        <!-- Statistics Section -->
        <Frame Style="{StaticResource CardFrame}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Beräkning Statistik" FontSize="20" FontAttributes="Bold" Style="{StaticResource SectionTitleLabel}" />
                
                <!-- Grundlön -->
                <Label Text="{Binding BaseSalaryText}" FontSize="14" />
                <Label Text="{Binding TotalHoursText}" FontSize="14" />

                <!-- OB Card -->
                <Frame HasShadow="True" CornerRadius="12" Padding="10" Margin="0,5"
                        BackgroundColor="White" BorderColor="#E0E0E0">

                    <VerticalStackLayout>
                        <!-- Header row -->
                        <Grid ColumnDefinitions="40,*,Auto" Padding="5">
                            <!-- Ikon -->
                            <Label Text="🌙" FontSize="20" VerticalOptions="Center" />

                            <!-- Titel + värde -->
                            <HorizontalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="OB-timmar:" FontAttributes="Bold" VerticalOptions="Center" Padding="0,0,10,0" />
                                <Label Text="{Binding TotalObHoursText}"
                                       FontAttributes="Bold"
                                       TextColor="{Binding ObHoursColor}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <!-- Chevron -->
                            <Label Text="{Binding ObCardChevronIcon}"
                                   FontSize="18"
                                   Grid.Column="2"
                                   VerticalOptions="Center"
                                   HorizontalOptions="End" />

                            <!-- 👈 Viktigt: gör headern klickbar -->
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleObCardCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <!-- Expandable content -->
                        <StackLayout x:Name="ObDetailsPanel" IsVisible="False" Opacity="0" Padding="5,10,5,0" Spacing="5">
                            <CollectionView ItemsSource="{Binding ObDetails}">
                                <CollectionView.EmptyView>
                                    <StackLayout Padding="10" HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="Inga OB-timmar registrerade denna månad."
                                               TextColor="Gray"
                                               FontAttributes="Italic"
                                               HorizontalOptions="Center" />
                                    </StackLayout>
                                </CollectionView.EmptyView>

                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*,*,*,*">
                                            <Label Text="{Binding Date, StringFormat='{0:MM-dd}'}" />
                                            <Label Text="{Binding CategoryName}" Grid.Column="1"/>
                                            <Label Text="{Binding Hours, StringFormat='{0:0.##} h'}" Grid.Column="2" />
                                            <Label Text="{Binding Pay, StringFormat='{0:C}'}" Grid.Column="3" TextColor="Green" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <!-- Total OB-lön -->
                            <Label Padding="0,10,0,0">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Total ersättning:    " FontAttributes="Bold"/>
                                        <Span Text="{Binding ObPayText, StringFormat='{}{0:C}'}" TextColor="{Binding ObHoursColor}"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </StackLayout>
                    </VerticalStackLayout>
                </Frame>

                <Label Text="{Binding ObPayText}" FontSize="14" />           <!-- Just nu försöker fixa detta -->
                
                <!--Ska går genom att dem ska visa rätt data-->
                <Label Text="{Binding FlexBalanceText}" FontSize="14" />
                <Label Text="{Binding SickDaysText}" FontSize="14" />
                <Label Text="{Binding VacationDaysText}" FontSize="14" />
                <Label Text="{Binding VabDaysText}" FontSize="14" />
                <Label Text="{Binding JourText}" FontSize="14" />
            </VerticalStackLayout>
        </Frame>

        

        <!-- Monthly Reports -->
        <!--<Frame Style="{StaticResource CardFrame}">
            <VerticalStackLayout Spacing="10">
                <Label Text="Månadsrapporter"
                       FontSize="18" Style="{StaticResource SectionTitleLabel}"
                       FontAttributes="Bold" />
                <CollectionView ItemsSource="{Binding MonthlyReports}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding MonthYear}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding ReportDetails}"
                                       FontSize="14" />
                                <Button Text="Visa detaljer"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewReportCommand}"
                                        CommandParameter="{Binding .}"
