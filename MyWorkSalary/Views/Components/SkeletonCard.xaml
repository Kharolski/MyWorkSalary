<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyWorkSalary.Views.Components.SkeletonCard">
    
    <ContentView.Resources>
        <ResourceDictionary>
            <!-- Skeleton animation -->
            <Style x:Key="SkeletonBox" TargetType="BoxView">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E0E0E0, Dark=#3A3A3A}" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>
            
            <Style x:Key="SkeletonText" TargetType="BoxView">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="HeightRequest" Value="16" />
            </Style>
        </ResourceDictionary>
    </ContentView.Resources>

    <Border Background="{AppThemeBinding Light=#FFFFFF, Dark=#1A1A1A}" 
        Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#404040}" 
        StrokeThickness="1" 
        StrokeShape="RoundRectangle 12" 
        Padding="16"
        WidthRequest="350" 
        HorizontalOptions="Center">
        <VerticalStackLayout Spacing="10" Padding="20">
            
            <!-- Header skeleton -->
            <BoxView Style="{StaticResource SkeletonText}" 
                     WidthRequest="120" 
                     HorizontalOptions="Start" />
            
            <!-- Content skeleton -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="25" RowSpacing="20">
                <!-- First row -->
                <BoxView Grid.Column="0" Grid.Row="0" Style="{StaticResource SkeletonText}" WidthRequest="60" />
                <BoxView Grid.Column="1" Grid.Row="0" Style="{StaticResource SkeletonText}" WidthRequest="60" />
                
                <!-- Second row -->
                <BoxView Grid.Column="0" Grid.Row="1" Style="{StaticResource SkeletonText}" WidthRequest="80" />
                <BoxView Grid.Column="1" Grid.Row="1" Style="{StaticResource SkeletonText}" WidthRequest="80" />
            </Grid>
            
            <!-- Button skeleton -->
            <BoxView Style="{StaticResource SkeletonBox}" 
                     HeightRequest="40" 
                     WidthRequest="100" 
                     HorizontalOptions="Center" />
        </VerticalStackLayout>
    </Border>
</ContentView>
