<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Lönestatistik stil -->
    <Style x:Key="SalaryAmountLabel" TargetType="Label">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="TextColor" 
            Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                   Dark={StaticResource White}}" />
    </Style>
    <Style x:Key="SalaryPositiveText" TargetType="Label">
        <Setter Property="TextColor" 
            Value="{AppThemeBinding Light={StaticResource SalaryPositiveLight}, 
                                   Dark={StaticResource SalaryPositiveDark}}" />
    </Style>
    <Style x:Key="SalaryNegativeText" TargetType="Label">
        <Setter Property="TextColor" 
            Value="{AppThemeBinding Light={StaticResource SalaryNegativeLight}, 
                                   Dark={StaticResource SalaryNegativeDark}}" />
    </Style>
    <Style x:Key="SalaryNeutralText" TargetType="Label">
        <Setter Property="TextColor" 
            Value="{AppThemeBinding Light={StaticResource SalaryNeutralLight}, 
                                   Dark={StaticResource SalaryNeutralDark}}" />
    </Style>
    
    <!-- Page Styles -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" 
            Value="{AppThemeBinding Light={StaticResource BackgroundPrimary}, 
                                   Dark={StaticResource BackgroundDark}}" />
    </Style>

    <!-- Shell Header Styles - Top -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" 
                Value="{AppThemeBinding Light={StaticResource BackgroundPrimary}, 
                                        Dark={StaticResource BackgroundDark}}" />
        <Setter Property="Shell.TitleColor" 
                Value="{AppThemeBinding Light={StaticResource SalaryPrimary}, 
                                        Dark={StaticResource SalaryPrimaryDark}}" />
        
        <Setter Property="Shell.ForegroundColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />

        <Setter Property="Shell.DisabledColor" 
                Value="{AppThemeBinding Light={StaticResource TextHint}, 
                                        Dark={StaticResource TextHintDark}}" />
        <Setter Property="Shell.UnselectedColor" 
                Value="{AppThemeBinding Light={StaticResource SalaryTabUnselected}, 
                                        Dark={StaticResource SalaryTabUnselectedDark}}" />

        <!-- Shell Tabbar Styles - Bottom -->
        <Setter Property="Shell.TabBarBackgroundColor" 
                Value="{AppThemeBinding Light={StaticResource BackgroundTab}, 
                                        Dark={StaticResource BackgroundDark}}" />
        <Setter Property="Shell.TabBarForegroundColor" 
                Value="{AppThemeBinding Light={StaticResource SalaryTabSelected}, 
                                        Dark={StaticResource White}}" />
        <Setter Property="Shell.TabBarTitleColor" 
                Value="{AppThemeBinding Light={StaticResource SalaryTabSelected}, 
                                        Dark={StaticResource White}}" />
        <Setter Property="Shell.TabBarUnselectedColor" 
                Value="{AppThemeBinding Light={StaticResource SalaryTabUnselected}, 
                                        Dark={StaticResource TextSecondary}}" />
    </Style>

    <!-- NavigationPage Styles -->
    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{AppThemeBinding Light={StaticResource BackgroundPrimary}, Dark={StaticResource BackgroundDark}}" />
        <Setter Property="BarTextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
        <Setter Property="IconColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
    </Style>

    <!-- Loading Overlay Styles -->
    <Style x:Key="LoadingOverlay" TargetType="Grid">
        <Setter Property="BackgroundColor" Value="{StaticResource LoadingOverlayColor}" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions" Value="Fill" />
        <Setter Property="ZIndex" Value="1000" />
    </Style>

    <Style x:Key="LoadingIndicator" TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="LoadingText" TargetType="Label">
        <Setter Property="Text" Value="Laddar..." />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource White}}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Margin" Value="0,60,0,0" />
    </Style>

    <!-- Shift Page Styles -->
    <Style TargetType="Border" x:Key="ActiveJobBorder">
        <Setter Property="Background">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource ActiveJobBackground}"
                             Dark="{StaticResource ActiveJobBackgroundDark}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="15" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Border" x:Key="EmptyStateBorder">
        <Setter Property="Background">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource EmptyStateBackground}"
                             Dark="{StaticResource EmptyStateBackgroundDark}" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="20" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Label" x:Key="ActiveJobTitleLabel">
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource White}}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Label" x:Key="PayLabel">
        <Setter Property="TextColor" Value="{StaticResource PayTextColor}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Label" x:Key="OBLabel">
        <Setter Property="TextColor" Value="{StaticResource OBTextColor}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="Label" x:Key="SectionHeaderLabel">
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- Add Shift Page Styles -->
    <Style TargetType="Label" x:Key="FieldLabel">
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style TargetType="Border" x:Key="CalculationBorder">
        <!-- Background -->
        <Setter Property="Background">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource CalculationBackground}"
                             Dark="{StaticResource CalculationBackgroundDark}" />
            </Setter.Value>
        </Setter>

        <!-- Stroke (mörkare grön) -->
        <Setter Property="Stroke">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource HolidayStroke}"
                         Dark="{StaticResource HolidayStrokeDark}" />
            </Setter.Value>
        </Setter>

        <!-- Padding -->
        <Setter Property="Padding" Value="15" />

        <!-- Border stroke thickness -->
        <Setter Property="StrokeThickness" Value="1" />

        <!-- Rounded corners -->
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="8" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Style för helgdagsborder -->
    <Style TargetType="Border" x:Key="HolidayBorder">
        <!-- Background -->
        <Setter Property="Background">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource HolidayBackground}"
                                 Dark="{StaticResource HolidayBackgroundDark}" />
            </Setter.Value>
        </Setter>

        <!-- Stroke (mörkare grön) -->
        <Setter Property="Stroke">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource HolidayStroke}"
                                 Dark="{StaticResource HolidayStrokeDark}" />
            </Setter.Value>
        </Setter>

        <!-- Padding -->
        <Setter Property="Padding" Value="12,8" />

        <!-- Border stroke thickness -->
        <Setter Property="StrokeThickness" Value="1" />

        <!-- Rounded corners -->
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="8" />
            </Setter.Value>
        </Setter>

        <!-- Margin -->
        <Setter Property="Margin" Value="0,8,0,0" />
    </Style>

    <Style TargetType="DatePicker" x:Key="ThemedDatePicker">
        <Setter Property="BackgroundColor" 
        Value="{AppThemeBinding Light={StaticResource InputBackground}, 
                               Dark={StaticResource InputBackgroundDark}}" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style TargetType="TimePicker" x:Key="ThemedTimePicker">
        <Setter Property="BackgroundColor" 
        Value="{AppThemeBinding Light={StaticResource InputBackground}, 
                               Dark={StaticResource InputBackgroundDark}}" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style TargetType="Picker" x:Key="ThemedPicker">
        <Setter Property="BackgroundColor" 
        Value="{AppThemeBinding Light={StaticResource InputBackground}, 
                               Dark={StaticResource InputBackgroundDark}}" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style TargetType="Editor" x:Key="ThemedEditor">
        <Setter Property="BackgroundColor" 
        Value="{AppThemeBinding Light={StaticResource InputBackground}, 
                               Dark={StaticResource InputBackgroundDark}}" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="PlaceholderColor" 
        Value="{AppThemeBinding Light={StaticResource TextHint}, 
                               Dark={StaticResource TextHintDark}}" />
    </Style>

    <!-- Settings Page Styles -->
    <Style TargetType="Label" x:Key="SectionTitleLabel">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource ButtonPrimary}" />
    </Style>

    <Style TargetType="Border" x:Key="OBRuleBorder">
        <Setter Property="Background">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource OBRuleBackground}"
                             Dark="{StaticResource OBRuleBackgroundDark}" />
            </Setter.Value>
        </Setter>

        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,2" />

        <Setter Property="StrokeThickness" Value="0" />

        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="8" />
            </Setter.Value>
        </Setter>
    </Style>


    <Style TargetType="Button" x:Key="EditButton">
        <Setter Property="BackgroundColor" Value="{StaticResource EditButtonColor}" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="0,12" />
    </Style>

    <Style TargetType="Button" x:Key="DeleteButton">
        <Setter Property="BackgroundColor" Value="{StaticResource ButtonDanger}" />
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="WidthRequest" Value="50" />
    </Style>

    <!-- Add OB Rate Page Styles -->
    <Style TargetType="Label" x:Key="FieldTitleLabel">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style TargetType="Label" x:Key="DayLabel">
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style TargetType="CheckBox" x:Key="ThemedCheckBox">
        <Setter Property="Color" Value="{StaticResource SalaryPrimary}" />
    </Style>

    <Style TargetType="Button" x:Key="WeekdaysButton">
        <Setter Property="BackgroundColor" 
        Value="{AppThemeBinding Light={StaticResource WeekdaysButtonColor}, 
                               Dark={StaticResource WeekdaysButtonColorDark}}" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource White}}" />
        <Setter Property="CornerRadius" Value="15" />
        <Setter Property="Padding" Value="15,8" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="Button" x:Key="WeekendsButton">
        <Setter Property="BackgroundColor" 
        Value="{AppThemeBinding Light={StaticResource WeekendsButtonColor}, 
                               Dark={StaticResource WeekendsButtonColorDark}}" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource White}}" />
        <Setter Property="CornerRadius" Value="15" />
        <Setter Property="Padding" Value="15,8" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="Button" x:Key="AllDaysButton">
        <Setter Property="BackgroundColor" 
        Value="{AppThemeBinding Light={StaticResource AllDaysButtonColor}, 
                               Dark={StaticResource AllDaysButtonColorDark}}" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource White}}" />
        <Setter Property="CornerRadius" Value="15" />
        <Setter Property="Padding" Value="15,8" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- Label Styles -->
    <Style TargetType="Label">
        <Setter Property="TextColor" 
            Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                   Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <!-- Tips Label Style -->
    <Style TargetType="Label" x:Key="TipsLabel">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" 
                Value="{AppThemeBinding Light={StaticResource TextHint}, 
                                       Dark={StaticResource TextHintDark}}" />
    </Style>

    <!-- Help Label Style -->
    <Style TargetType="Label" x:Key="HelpLabel">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" 
            Value="{AppThemeBinding Light={StaticResource TextSecondary}, 
                                   Dark={StaticResource TextSecondaryDark}}" />
    </Style>

    <!-- Tom data Label Style -->
    <Style TargetType="Label" x:Key="NoItemsLabel">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextEmptyList}, 
                               Dark={StaticResource TextEmptyListDark}}" />
    </Style>

    <!-- OB list Label Style -->
    <Style TargetType="Label" x:Key="OBHeaderLabel">
        <Setter Property="TextColor" 
                Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                       Dark={StaticResource White}}" />
    </Style>

    <Style TargetType="Label" x:Key="OBInfoLabel">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" 
                Value="{AppThemeBinding Light={StaticResource TextSecondary}, 
                                       Dark={StaticResource TextSecondaryDark}}" />
    </Style>

    <!-- OB Template Labels Style -->
    <Style TargetType="Label" x:Key="OBTemplateTitleListLabel">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="OpenSansBold" />
        <Setter Property="TextColor" 
                Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                        Dark={StaticResource White}}" />
    </Style>

    <Style TargetType="Label" x:Key="ActiveJob">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" 
            Value="{AppThemeBinding Light={StaticResource ActiveJobLight}, 
                                   Dark={StaticResource ActiveJobDark}}" />
    </Style>

    <Style TargetType="Label" x:Key="QuestionLabel">
        <Setter Property="TextColor" 
                Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                       Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="TitleLabel">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource SalaryPrimary}, Dark={StaticResource White}}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="SalaryLabel">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Success}, Dark={StaticResource Success}}" />
        <Setter Property="FontFamily" Value="OpenSansBold" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="HorizontalOptions" Value="Center" />
    </Style>

    <Style TargetType="Label" x:Key="SecondaryLabel">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondary}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Label" x:Key="ValidationLabel">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Error}, Dark={StaticResource Error}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- Holiday visning -->
    <Style TargetType="Label" x:Key="HolidayAutoDetected">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" 
            Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource TextSecondaryDark}}" />
    </Style>
    <Style TargetType="Label" x:Key="HolidayTitle">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource White}}" />
    </Style>

    <!-- Entry Styles -->
    <Style TargetType="Entry" x:Key="ThemedEntry">
        <Setter Property="BackgroundColor" 
        Value="{AppThemeBinding Light={StaticResource InputBackground}, 
                               Dark={StaticResource InputBackgroundDark}}" />
        <Setter Property="TextColor" 
        Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                               Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="PlaceholderColor" 
        Value="{AppThemeBinding Light={StaticResource TextHint}, 
                               Dark={StaticResource TextHintDark}}" />
    </Style>

    <!-- Button Styles -->
    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SalaryPrimary}, Dark={StaticResource SalaryPrimaryDark}}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
    </Style>

    <Style TargetType="Button" x:Key="SecondaryButton">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ButtonCancelText}, Dark={StaticResource White}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ButtonCancel}, Dark={StaticResource ButtonCancel}}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
    </Style>

    <Style TargetType="Button" x:Key="ButtonAdd">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ButtonCancelText}, Dark={StaticResource White}}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ButtonPrimary}, Dark={StaticResource ButtonPrimary}}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="MinimumHeightRequest" Value="48"/>
    </Style>

    <!-- Frame/Card Styles -->
    <Style TargetType="Border" x:Key="CardBorder">
        <Setter Property="Background" 
            Value="{AppThemeBinding Light={StaticResource SalaryCardBackground}, 
                                   Dark={StaticResource SalaryCardBackgroundDark}}" />
        <Setter Property="Stroke" 
            Value="{AppThemeBinding Light={StaticResource BorderColor}, 
                                   Dark={StaticResource BorderColorDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="12" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style TargetType="Label" x:Key="CardTitleLabel">
        <Setter Property="TextColor" 
            Value="{AppThemeBinding Light={StaticResource TextPrimary}, 
                                   Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- InfoFrame Style -->
    <Style TargetType="Border" x:Key="InfoBorder">
        <!-- Background -->
        <Setter Property="Background">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource InfoFrameBackground}"
                             Dark="{StaticResource InfoFrameBackgroundDark}" />
            </Setter.Value>
        </Setter>

        <!-- Padding -->
        <Setter Property="Padding" Value="15" />

        <!-- Border color -->
        <Setter Property="Stroke">
            <Setter.Value>
                <AppThemeBinding Light="{StaticResource BorderColor}"
                             Dark="{StaticResource BorderColorDark}" />
            </Setter.Value>
        </Setter>

        <!-- Border thickness -->
        <Setter Property="StrokeThickness" Value="1" />

        <!-- Rounded corners -->
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="10" />
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ThemedSlider Style -->
    <Style TargetType="Slider" x:Key="ThemedSlider">
        <Setter Property="ThumbColor" Value="{StaticResource SalaryPrimary}" />
        <Setter Property="MinimumTrackColor" Value="{StaticResource SalaryPrimary}" />
        <Setter Property="MaximumTrackColor" 
            Value="{AppThemeBinding Light={StaticResource BorderColor},
                                   Dark={StaticResource BorderColorDark}}" />
    </Style>

</ResourceDictionary>
