<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Grundfärger -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>

    <!-- Bakgrunder -->
    <Color x:Key="AppBackground">#FAFAFA</Color>                <!-- För HomePage -->
    <Color x:Key="BackgroundPrimary">#EAEAEA</Color>            <!-- För Style.xaml -->

    <!-- Mörka bakgrunder -->
    <Color x:Key="BackgroundDark">#2C2C2C</Color>
    <Color x:Key="SurfaceDark">#1E1E1E</Color>

    <!-- MyWorkSalary färger -->
    <!-- Huvudfärger -->
    <Color x:Key="SalaryPrimary">#2E7D32</Color>                <!-- Professionell grön -->
    <Color x:Key="SalaryPrimaryDark">#4CAF50</Color>            <!-- Mörkare grön för dark mode -->
    <Color x:Key="SalarySecondary">#1976D2</Color>              <!-- Blå accent -->

    <!-- Status färger -->
    <Color x:Key="Success">#4CAF50</Color>                      <!-- Grön för positiva belopp -->
    <Color x:Key="Warning">#FF9800</Color>                      <!-- Orange för varningar -->
    <Color x:Key="Error">#F44336</Color>                        <!-- Röd för fel -->

    <!-- Text färger -->
    <Color x:Key="TextPrimary">#212121</Color>                  <!-- Mörk text -->
    <Color x:Key="TextSecondary">#757575</Color>                <!-- Grå text -->
    <Color x:Key="TextHint">#BDBDBD</Color>                     <!-- Placeholder -->

    <!-- Mörka text-färger -->
    <Color x:Key="TextPrimaryDark">#FFFFFF</Color>
    <Color x:Key="TextSecondaryDark">#B0B0B0</Color>
    
    <Color x:Key="ActiveJobBlue">#2986cc</Color>

    <!-- Bakgrunder -->
    <Color x:Key="SalaryCardBackground">#FFFFFF</Color>         <!-- Vit kort -->
    <Color x:Key="SalaryCardBackgroundDark">#1E1E1E</Color>     <!-- Mörk bakgrund -->

    <!-- Knapp färger -->
    <Color x:Key="ButtonPrimary">#2E7D32</Color>                <!-- Grön primär knapp -->
    <Color x:Key="ButtonCancel">#E57373</Color>                 <!-- Ljusröd för avbryt -->
    <Color x:Key="ButtonCancelText">#FFFFFF</Color>             <!-- Vit text för avbryt -->
    <Color x:Key="ButtonDanger">#F44336</Color>                 <!-- Röd för farliga åtgärder -->

    <!-- Tab färger -->
    <Color x:Key="SalaryTabSelected">#2E7D32</Color>            <!-- Grön för vald tab -->
    <Color x:Key="SalaryTabUnselected">#757575</Color>          <!-- Grå för ej vald -->

</ResourceDictionary>
