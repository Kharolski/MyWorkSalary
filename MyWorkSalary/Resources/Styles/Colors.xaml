<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ===== GRUNDFÄRGER ===== -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Transparent">Transparent</Color>

    <!-- ===== LABEL ===== -->
    <Color x:Key="ActiveJobLight">#478fd0</Color>
    <Color x:Key="ActiveJobDark">#5B9BD5</Color>

    <!-- ===== SPECIALFÄRGER ===== -->
    <Color x:Key="OverlayColor">#80000000</Color>
    <Color x:Key="ShadowColor">#1A000000</Color>
    <Color x:Key="LoadingOverlayColor">#CC000000</Color>

    <!-- ===== HUVUDFÄRGER ===== -->
    <Color x:Key="SalaryPrimary">#2E7D32</Color>
    <Color x:Key="SalaryPrimaryDark">#4CAF50</Color>
    <Color x:Key="SalarySecondary">#1976D2</Color>
    <Color x:Key="ActiveJobBlue">#2986cc</Color>

    <!-- ===== STATUS FÄRGER ===== -->
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FF9800</Color>
    <Color x:Key="Error">#F44336</Color>

    <!-- ===== KNAPP FÄRGER ===== -->
    <Color x:Key="ButtonPrimary">#5A8A5A</Color>
    <Color x:Key="ButtonCancel">#E57373</Color>
    <Color x:Key="ButtonCancelText">#FFFFFF</Color>
    <Color x:Key="ButtonDanger">#F44336</Color>
    <Color x:Key="SalaryTabSelected">#2E7D32</Color>

    <!-- ===== SPECIALFÄRGER FÖR SHIFT PAGE ===== -->
    <Color x:Key="ActiveJobBackground">#E3F2FD</Color>
    <Color x:Key="ActiveJobBackgroundDark">#3484ca</Color>
    <Color x:Key="EmptyStateBackground">#F5F5F5</Color>
    <Color x:Key="EmptyStateBackgroundDark">#424242</Color>
    <Color x:Key="PayTextColor">#2E7D32</Color>
    <Color x:Key="OBTextColor">#F57C00</Color>

    <!-- ===== SPECIALFÄRGER FÖR ADD SHIFT PAGE ===== -->
    <Color x:Key="CalculationBackground">#E8F5E8</Color>
    <Color x:Key="CalculationBackgroundDark">#5A8A5A</Color>
    <Color x:Key="InputBackground">#FFFFFF</Color>
    <Color x:Key="InputBackgroundDark">#3A3A3A</Color>

    <!-- ===== NYA FÄRGER FÖR INFOFRAME ===== -->
    <Color x:Key="InfoFrameBackground">#FFF3E0</Color>
    <Color x:Key="InfoFrameBackgroundDark">#5D4037</Color>

    <!-- ===== SPECIALFÄRGER FÖR SETTINGS PAGE ===== -->
    <Color x:Key="EditButtonColor">#d5955b</Color>
    <Color x:Key="OBRuleBackground">#E3F2FD</Color>
    <Color x:Key="OBRuleBackgroundDark">#1565C0</Color>

    <!-- ===== SPECIALFÄRGER FÖR ADD OB RATE PAGE ===== -->
    <Color x:Key="WeekdaysButtonColor">#E3F2FD</Color>
    <Color x:Key="WeekdaysButtonColorDark">#1976D2</Color>
    <Color x:Key="WeekendsButtonColor">#E8F5E8</Color>
    <Color x:Key="WeekendsButtonColorDark">#388E3C</Color>
    <Color x:Key="AllDaysButtonColor">#FFEBEE</Color>
    <Color x:Key="AllDaysButtonColorDark">#D32F2F</Color>

    <!-- ===== NYA FÄRGER FÖR LÖNESTATISTIK ===== -->
    <!-- Färger för lönestatistik - Ljust tema -->
    <Color x:Key="SalaryPositiveLight">#2E7D32</Color>      <!-- Mörkgrönt -->
    <Color x:Key="SalaryNegativeLight">#B23A3A</Color>      <!-- Mörkrött -->
    <Color x:Key="SalaryNeutralLight">#424242</Color>       <!-- Mörkgrå -->
    <Color x:Key="SalaryTextLight">#FFFFFF</Color>          <!-- Vit text -->
    
    <!-- Färger för lönestatistik - Mörkt tema -->
    <Color x:Key="SalaryPositiveDark">#81C784</Color>       <!-- Ljusare grönt -->
    <Color x:Key="SalaryNegativeDark">#EF9A9A</Color>       <!-- Ljusare rött -->
    <Color x:Key="SalaryNeutralDark">#E0E0E0</Color>        <!-- Ljusgrå -->
    <Color x:Key="SalaryTextDark">#212121</Color>           <!-- Mörkgrå text -->

    <!-- ============================== LJUST TEMA ============================= -->
    <Color x:Key="AppBackground">#FAFAFA</Color>
    <Color x:Key="BackgroundPrimary">#EAEAEA</Color>
    <Color x:Key="BackgroundTab">#DDDDDD</Color>
    <Color x:Key="SalaryCardBackground">#FFFFFF</Color>

    <Color x:Key="TextPrimary">#212121</Color>
    <Color x:Key="TextSecondary">#757575</Color>
    <Color x:Key="TextHint">#BDBDBD</Color>
    <Color x:Key="TextEmptyList">#444444</Color>

    <Color x:Key="SalaryTabUnselected">#757575</Color>
    <Color x:Key="BorderColor">#E0E0E0</Color>
    <Color x:Key="SeparatorColor">#F0F0F0</Color>

    <Color x:Key="SwitchTrackOff">#E0E0E0</Color>
    <Color x:Key="SwitchThumbLight">#2E7D32</Color>

    <!-- ============================== MÖRKT TEMA ============================= -->
    <Color x:Key="AppBackgroundDark">#1A1A1A</Color>
    <Color x:Key="BackgroundDark">#252525</Color>
    <Color x:Key="SurfaceDark">#2F2F2F</Color>
    <Color x:Key="SalaryCardBackgroundDark">#353535</Color>

    <Color x:Key="TextPrimaryDark">#FFFFFF</Color>
    <Color x:Key="TextSecondaryDark">#9a9a9a</Color>
    <Color x:Key="TextHintDark">#B3B3B3</Color>
    <Color x:Key="TextEmptyListDark">#DADADA</Color>

    <Color x:Key="SalaryTabUnselectedDark">#999999</Color>
    <Color x:Key="BorderColorDark">#404040</Color>
    <Color x:Key="SeparatorColorDark">#3D3D3D</Color>

    <Color x:Key="SwitchTrackOffDark">#616161</Color>
    <Color x:Key="SwitchThumbDark">#FFFFFF</Color>

    <!-- ===== HELGDAG FÄRGER (MÖRKARE STROKE) ===== -->
    <Color x:Key="HolidayBackground">#E8F5E8</Color>        <!-- Samma som CalculationBackground -->
    <Color x:Key="HolidayBackgroundDark">#5A8A5A</Color>    <!-- Samma som CalculationBackgroundDark -->
    <Color x:Key="HolidayStroke">#4CAF50</Color>            <!-- Mörkare grön stroke -->
    <Color x:Key="HolidayStrokeDark">#388E3C</Color>        <!-- Mörkare grön stroke (dark mode) -->

</ResourceDictionary>
