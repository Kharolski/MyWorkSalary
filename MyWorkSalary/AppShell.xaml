<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MyWorkSalary.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MyWorkSalary.Views"
    Title="MyWorkSalary" BackgroundColor="{StaticResource AppBackground}">

    <TabBar>
        <ShellContent
            Title="Hem"
            Icon="{FontImageSource Glyph='●', FontFamily='Arial', Size=20}"
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="HomePage" />

        <ShellContent
            Title="Pass"
            Icon="{FontImageSource Glyph='+', FontFamily='Arial', Size=24}"
            ContentTemplate="{DataTemplate views:AddShiftPage}"
            Route="AddShiftPage" />

        <ShellContent
            Title="Lön"
            Icon="{FontImageSource Glyph='$', FontFamily='Arial', Size=20}"
            ContentTemplate="{DataTemplate views:SalaryPage}"
            Route="SalaryPage" />

        <ShellContent
            Title="Inställningar"
            Icon="{FontImageSource Glyph='⚙', FontFamily='Arial', Size=20}"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
