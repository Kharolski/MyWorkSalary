<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MyWorkSalary.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:MyWorkSalary.Views"
    Title="MyWorkSalary">
    <!-- BackgroundColor kommer nu från Shell Style -->

    <TabBar>
        <ShellContent
            Title="Hem"
            Icon="home.png"
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="HomePage" />

        <ShellContent
            Title="Pass"
            Icon="pass.png"
            ContentTemplate="{DataTemplate views:ShiftPage}"
            Route="ShiftPage" />

        <ShellContent
            Title="Lön"
            Icon="raport.png"
            ContentTemplate="{DataTemplate views:SalaryPage}"
            Route="SalaryPage" />

        <ShellContent
            Title="Inställningar"
            Icon="settings.png"
            ContentTemplate="{DataTemplate views:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
